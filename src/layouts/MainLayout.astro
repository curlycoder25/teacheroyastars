---
// hideNavbar əlavə edildi
const { title, hideHeader = false, hideNavbar = false, isIndex = false } = Astro.props; 
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(/^\/|\/$/g, "");

const activeClass = "bg-[#b5161e] text-white rounded-full px-5 py-2 flex flex-col items-center transition-all duration-300 shadow-md scale-95";
const inactiveClass = "text-[#213041] opacity-60 flex flex-col items-center px-5 py-2 transition-all duration-300 hover:opacity-100";
---

<html lang="az">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
        <title>{title} | Teacher Roya’s Stars</title>
        
        <script src="https://cdn.tailwindcss.com"></script>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet"/>

        <style is:global>
            body { font-family: 'Plus Jakarta Sans', sans-serif; margin: 0; -webkit-tap-highlight-color: transparent; }
            .material-symbols-outlined {
                font-family: 'Material Symbols Outlined' !important;
                font-size: 24px;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .celestial-bg {
                background: radial-gradient(circle at top right, #e2e8f0, #f3f6ff);
                min-height: 100vh;
            }
            ::-webkit-scrollbar { width: 0px; background: transparent; }
        </style>
    </head>
    
    <body class="bg-[#f3f6ff] text-[#213041] celestial-bg relative overflow-x-hidden">
        
        {!hideHeader && (
            <header class="fixed top-0 w-full z-50 bg-[#f3f6ff]/80 backdrop-blur-xl border-b border-[#d1e4ff]">
                <div class="flex items-center justify-between px-6 py-4 max-w-5xl mx-auto">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[#b5161e]" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                        <h1 class="text-xl font-black tracking-tighter">
                            <span class="text-[#155f98]">Teacher </span><span class="text-[#b5161e]">Roya’s</span> <span class="text-[#155f98]">Stars</span>
                        </h1>
                    </div>

                    <div>
                        {isIndex ? (
                            <button class="font-bold text-[#b5161e] text-sm active:scale-90 transition-transform">Sign Up</button>
                        ) : (
                            <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-[#d1e4ff] shadow-sm bg-[#83bdfd] flex items-center justify-center text-white font-bold text-xs">
                                JD
                            </div>
                        )}
                    </div>
                </div>
            </header>
        )}

        <main class:list={[
            "px-6 max-w-5xl mx-auto relative",
            {"pt-24": !hideHeader}, // Header varsa padding
            {"pt-8": hideHeader},  // Header yoxdursa az padding
            {"pb-32": !hideNavbar}, // Navbar varsa padding
            {"pb-8": hideNavbar}   // Navbar yoxdursa az padding
        ]}>
            <slot />
        </main>

        {!hideNavbar && (
            <nav class="fixed bottom-0 left-0 w-full z-50 bg-white/90 backdrop-blur-xl rounded-t-[2.5rem] shadow-[0_-8px_30px_rgb(0,0,0,0.06)] px-2 pb-8 pt-4 flex justify-around items-center border-t border-white/50">
                <a href="/" class="flex flex-col items-center no-underline">
                    <div class={currentPath === "" ? activeClass : inactiveClass}>
                        <span class="material-symbols-outlined" style={currentPath === "" ? "font-variation-settings: 'FILL' 1;" : ""}>home</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest mt-0.5">Home</span>
                    </div>
                </a>
                <a href="/topics" class="flex flex-col items-center no-underline">
                    <div class={currentPath === "topics" ? activeClass : inactiveClass}>
                        <span class="material-symbols-outlined" style={currentPath === "topics" ? "font-variation-settings: 'FILL' 1;" : ""}>rocket_launch</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest mt-0.5">Topics</span>
                    </div>
                </a>
                <a href="/exam" class="flex flex-col items-center no-underline">
                    <div class={currentPath === "exam" ? activeClass : inactiveClass}>
                        <span class="material-symbols-outlined" style={currentPath === "exam" ? "font-variation-settings: 'FILL' 1;" : ""}>quiz</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest mt-0.5">Exam</span>
                    </div>
                </a>
                <a href="/profile" class="flex flex-col items-center no-underline">
                    <div class={currentPath === "profile" ? activeClass : inactiveClass}>
                        <span class="material-symbols-outlined" style={currentPath === "profile" ? "font-variation-settings: 'FILL' 1;" : ""}>person</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest mt-0.5">Profile</span>
                    </div>
                </a>
            </nav>
        )}
    </body>
</html>