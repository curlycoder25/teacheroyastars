---
const { title, hideHeader = false, hideNavbar = false, isIndex = false } = Astro.props; 
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(/^\/|\/$/g, "");

// Mobil Naviqasiya (Aşağıdakı bar)
const mobileActiveClass = "bg-[#b5161e] text-white rounded-full px-3 py-1.5 flex flex-col items-center transition-all duration-300 shadow-md scale-95";
const mobileInactiveClass = "text-[#213041] opacity-50 flex flex-col items-center px-3 py-1.5 transition-all duration-300";

// Desktop Naviqasiya
const desktopActiveClass = "text-[#b5161e] font-black border-b-2 border-[#b5161e] pb-1 flex items-center gap-2 transition-all text-sm uppercase tracking-widest";
const desktopInactiveClass = "text-[#213041] opacity-60 font-bold hover:opacity-100 flex items-center gap-2 transition-all text-sm uppercase tracking-widest";
---

<html lang="az">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
        <title>{title} | Teacher Roya’s Stars</title>
        
        <script src="https://cdn.tailwindcss.com"></script>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet"/>

        <style is:global>
            body { 
                font-family: 'Plus Jakarta Sans', sans-serif; 
                margin: 0; 
                -webkit-tap-highlight-color: transparent;
                overflow-x: hidden;
            }
            
            .material-symbols-outlined {
                font-family: 'Material Symbols Outlined' !important;
                font-size: 20px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            /* MOBİL MASTER DÜZƏLİŞLƏR */
            @media (max-width: 768px) {
                .logo-text { font-size: 11px !important; }
                .logo-icon { font-size: 18px !important; }
                h1 { font-size: 1.2rem !important; }
                h2 { font-size: 1rem !important; }
                
                section, .signup-card, .login-card, .lesson-card, .question-container, .feedback-container {
                    padding-left: 1rem !important;
                    padding-right: 1rem !important;
                    border-radius: 24px !important;
                }
            }

            .celestial-bg {
                /* Fon rəngi bütün bədəni əhatə etməlidir */
                background: radial-gradient(circle at top right, #e2e8f0, #f3f6ff);
                min-height: 100vh;
                background-attachment: fixed;
            }
            
            ::-webkit-scrollbar { width: 0px; }
            
            @media (min-width: 1024px) {
                .mobile-nav { display: none; }
            }
        </style>
    </head>
    
    <body class="celestial-bg text-[#213041] relative">
        
        {!hideHeader && (
            <header class="fixed top-0 w-full z-[100] bg-white/80 backdrop-blur-xl border-b border-[#d1e4ff]">
                <div class="flex items-center justify-between px-3 md:px-10 py-2 w-full max-w-[1300px] mx-auto">
                    
                    <div class="flex items-center gap-1 group no-underline whitespace-nowrap flex-shrink">
                        <span class="material-symbols-outlined text-[#b5161e] logo-icon md:!text-3xl transition-transform" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                        <h1 class="logo-text md:text-xl font-black tracking-tighter uppercase leading-none">
                            <span class="text-[#155f98]">Teacher </span><span class="text-[#af101a]">Roya’s</span> <span class="text-[#155f98]">Stars</span>
                        </h1>
                    </div>

                    {!hideNavbar && (
                        <nav class="hidden lg:flex items-center gap-8 px-4">
                            </nav>
                    )}

                    <div class="flex justify-end flex-shrink-0">
                        {isIndex ? (
                            <button class="bg-[#af101a] text-white px-3 md:px-8 py-1.5 md:py-2.5 rounded-full font-bold text-[9px] md:text-sm shadow-lg shadow-red-900/10 active:scale-95 transition-all">
                                Sign Up
                            </button>
                        ) : (
                            <a href="/profile" class="flex flex-col items-center gap-0.5 group no-underline">
                                <div class="w-7 h-7 md:w-9 md:h-9 rounded-full bg-[#83bdfd] flex items-center justify-center text-white font-bold text-[9px] border-2 border-white">
                                    JD
                                </div>
                                <span class="text-[6px] md:text-[8px] font-black uppercase tracking-widest text-[#155f98] opacity-50">Profile</span>
                            </a>
                        )}
                    </div>
                </div>
            </header>
        )}

        <main class:list={[
            "w-full relative", 
            {"pt-14 md:pt-28": !hideHeader}, 
            {"pb-32 lg:pb-12": !hideNavbar}
        ]}>
            <slot />
        </main>

        {!hideNavbar && (
            <nav class="mobile-nav lg:hidden fixed bottom-0 left-0 w-full z-50 bg-white/95 backdrop-blur-xl rounded-t-[1.5rem] shadow-[0_-4px_20px_rgba(0,0,0,0.05)] px-2 pb-5 pt-2 flex justify-around items-center border-t border-white/50">
                <a href="/" class="no-underline">
                    <div class={currentPath === "" ? mobileActiveClass : mobileInactiveClass}>
                        <span class="material-symbols-outlined !text-lg">home</span>
                        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5">Home</span>
                    </div>
                </a>
                <a href="/topics" class="no-underline">
                    <div class={currentPath === "topics" ? mobileActiveClass : mobileInactiveClass}>
                        <span class="material-symbols-outlined !text-lg">rocket_launch</span>
                        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5">Topics</span>
                    </div>
                </a>
                <a href="/exam" class="no-underline">
                    <div class={currentPath === "exam" ? mobileActiveClass : mobileInactiveClass}>
                        <span class="material-symbols-outlined !text-lg">quiz</span>
                        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5">Exam</span>
                    </div>
                </a>
                <a href="/profile" class="no-underline">
                    <div class={currentPath === "profile" ? mobileActiveClass : mobileInactiveClass}>
                        <span class="material-symbols-outlined !text-lg">person</span>
                        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5">Profile</span>
                    </div>
                </a>
            </nav>
        )}
    </body>
</html>