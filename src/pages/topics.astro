---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Topics">
    
    <main class="pt-24 pb-32 px-6 max-w-5xl mx-auto relative overflow-hidden">
        
        <div class="absolute top-20 right-10 opacity-20 pointer-events-none">
            <span class="material-symbols-outlined !text-4xl text-tertiary" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>
        <div class="absolute bottom-40 left-5 opacity-10 scale-150 pointer-events-none">
            <span class="material-symbols-outlined !text-6xl text-primary">rocket_launch</span>
        </div>

        <section class="mb-10">
            <h2 class="text-3xl font-black text-on-surface tracking-tight mb-2">Learning Universe</h2>
            <p class="text-on-surface/60 font-medium text-sm max-w-xs">Embark on your journey through the grammar galaxies. Every star earned brings you closer to mastery!</p>
        </section>

        <div class="grid grid-cols-1 gap-6">
            
            <div class="relative group p-6 rounded-4xl bg-secondary shadow-xl shadow-secondary/20 overflow-hidden transition-all active:scale-[0.98]">
                <div class="absolute top-4 right-6 opacity-90">
                    <span class="material-symbols-outlined !text-[64px] text-tertiary" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div class="flex flex-col h-full justify-between relative z-10">
                    <div>
                        <span class="inline-block px-3 py-1 rounded-full bg-white/20 text-white text-[10px] font-black uppercase tracking-widest mb-4">Completed</span>
                        <h3 class="text-xl font-black text-white mb-2 pr-12">Topic 01: Nouns & Objects</h3>
                        <p class="text-white/80 text-sm mb-6 pr-12">Mastering the building blocks of every sentence in the universe.</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex justify-between items-end">
                            <span class="text-white/70 text-[10px] font-black uppercase">Progress</span>
                            <span class="text-white text-sm font-black">100%</span>
                        </div>
                        <div class="h-2 w-full bg-white/20 rounded-full overflow-hidden">
                            <div class="h-full bg-tertiary w-full rounded-full shadow-[0_0_10px_rgba(255,179,0,0.5)]"></div>
                        </div>
                        <button class="w-full mt-4 py-3 bg-white text-secondary font-black rounded-full text-sm active:scale-95 transition-all">Review Lesson</button>
                    </div>
                </div>
            </div>

            <div class="relative group p-6 rounded-4xl bg-white border border-primary/5 shadow-sm overflow-hidden transition-all active:scale-[0.98]">
                <div class="absolute top-4 right-6 flex items-center justify-center">
                    <div class="relative inline-block leading-none">
                        <span class="material-symbols-outlined !text-[64px] text-surface-variant/30" style="font-variation-settings: 'FILL' 1;">
                            star
                        </span>
                        <div class="absolute top-0 left-0 overflow-hidden h-full pointer-events-none" style="width: 65%;">
                            <span class="material-symbols-outlined !text-[64px] text-tertiary" style="font-variation-settings: 'FILL' 1;">
                                star
                            </span>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col h-full justify-between">
                    <div>
                        <span class="inline-block px-3 py-1 rounded-full bg-secondary/10 text-secondary text-[10px] font-black uppercase tracking-widest mb-4">In Progress</span>
                        <h3 class="text-xl font-black text-on-surface mb-2 pr-12">Topic 02: Action Verbs</h3>
                        <p class="text-on-surface/60 text-sm mb-6 pr-12">Giving life and motion to your stories through powerful verbs.</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex justify-between items-end">
                            <span class="text-on-surface/40 text-[10px] font-black uppercase">Current Orbit</span>
                            <span class="text-secondary text-sm font-black">65%</span>
                        </div>
                        <div class="h-2 w-full bg-surface rounded-full overflow-hidden border border-primary/5">
                            <div class="h-full bg-tertiary w-[65%] rounded-full relative shadow-[0_0_12px_rgba(255,179,0,0.4)]"></div>
                        </div>
                        <button class="w-full mt-4 py-3 bg-secondary text-white font-black rounded-full text-sm active:scale-95 transition-all shadow-lg shadow-secondary/20">Continue Mission</button>
                    </div>
                </div>
            </div>

            <div class="relative p-6 rounded-4xl bg-surface-variant/30 border border-primary/5 grayscale opacity-60">
                <div class="absolute inset-0 flex items-center justify-center z-10">
                    <div class="bg-white/80 p-3 rounded-full shadow-lg">
                        <span class="material-symbols-outlined text-on-surface/40">lock</span>
                    </div>
                </div>
                <div class="flex flex-col h-full justify-between blur-[1px]">
                    <div>
                        <span class="inline-block px-3 py-1 rounded-full bg-on-surface/5 text-on-surface/40 text-[10px] font-black uppercase tracking-widest mb-4">Not Started</span>
                        <h3 class="text-xl font-black text-on-surface/40 mb-2">Topic 03: Simple Tenses</h3>
                        <p class="text-on-surface/40 text-sm mb-6">Navigating the timelines of past, present, and the future horizons.</p>
                    </div>
                    <button class="w-full mt-4 py-3 bg-on-surface/10 text-on-surface/40 font-black rounded-full text-sm cursor-not-allowed">Locked</button>
                </div>
            </div>
        </div>

        <section class="mt-12 bg-white/60 backdrop-blur-md rounded-4xl p-8 border border-white flex flex-col items-center gap-6 shadow-sm">
            <div class="relative w-32 h-32">
                <svg class="w-full h-full transform -rotate-90">
                    <circle class="text-surface" cx="64" cy="64" fill="transparent" r="58" stroke="currentColor" stroke-width="8"></circle>
                    <circle class="text-tertiary" cx="64" cy="64" fill="transparent" r="58" stroke="currentColor" stroke-width="10" stroke-dasharray="364.4" stroke-dashoffset="182.2" stroke-linecap="round"></circle>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span class="text-2xl font-black text-on-surface">50%</span>
                    <span class="text-[10px] font-black text-on-surface/40 uppercase">Overall</span>
                </div>
            </div>
            <div class="text-center">
                <h4 class="text-lg font-black mb-1">Stellar progress!</h4>
                <p class="text-on-surface/60 text-xs mb-4">Keep going to reach: <span class="text-secondary font-black uppercase">Star Voyager</span>.</p>
                <div class="flex gap-3 justify-center">
                    <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-sm border border-primary/5">
                        <span class="material-symbols-outlined text-tertiary !text-lg" style="font-variation-settings: 'FILL' 1;">stars</span>
                        <span class="font-black text-xs text-on-surface">12 Stars</span>
                    </div>
                    <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-sm border border-primary/5">
                        <span class="material-symbols-outlined text-blue-500 !text-lg" style="font-variation-settings: 'FILL' 1;">bolt</span>
                        <span class="font-black text-xs text-on-surface">4 Days</span>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>