---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/card.astro';
---

<MainLayout title="Topics">
    <main class="pt-24 pb-32 px-6 max-w-5xl mx-auto relative overflow-hidden">
        
        <div class="absolute top-20 right-10 opacity-20 pointer-events-none select-none">
            <span class="material-symbols-outlined !text-4xl text-tertiary" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>

        <section class="mb-10 text-center md:text-left">
            <h2 class="text-3xl md:text-4xl font-black text-on-surface tracking-tight mb-2 italic uppercase">
                Learning Universe
            </h2>
            <p class="text-on-surface/60 font-medium text-sm max-w-md leading-relaxed">
                Embark on your journey through the grammar galaxies. Every star earned brings you closer to mastery!
            </p>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <Card 
                variant="red"
                href="/subtopics"
                badgeText="Completed"
                title="Topic 01: Nouns & Objects"
                description="Mastering the building blocks of every sentence in the universe."
                progress="100"
                iconName="star"
            />

            <Card 
                variant="white"
                href="/verbs"
                badgeText="In Progress"
                title="Topic 02: Action Verbs"
                description="Giving life and motion to your celestial stories through powerful verbs."
                progress="65"
                iconName="bolt"
            />

            <Card 
                variant="gray"
                title="Topic 03: Simple Tenses"
                description="Navigating the timelines of past, present, and the future horizons."
                iconName="lock"
            />

        </div>

        <section class="mt-12 bg-white/60 backdrop-blur-md rounded-[40px] p-8 border border-white flex flex-col md:flex-row items-center gap-10 shadow-sm relative overflow-hidden">
            </section>
    </main>
</MainLayout>