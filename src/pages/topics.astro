---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Topics">
    <main class="pt-24 pb-32 px-6 max-w-5xl mx-auto relative overflow-hidden">
        
        <div class="absolute top-20 right-10 opacity-20 pointer-events-none select-none">
            <span class="material-symbols-outlined !text-4xl text-tertiary" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>
        <div class="absolute bottom-40 left-5 opacity-10 scale-150 pointer-events-none select-none">
            <span class="material-symbols-outlined !text-6xl text-primary">rocket_launch</span>
        </div>

        <section class="mb-10 text-center md:text-left">
            <h2 class="text-3xl md:text-4xl font-black text-on-surface tracking-tight mb-2 italic uppercase">
                Learning Universe
            </h2>
            <p class="text-on-surface/60 font-medium text-sm max-w-md leading-relaxed">
                Embark on your journey through the grammar galaxies. Every star earned brings you closer to mastery!
            </p>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            
            <a href="/subtopics" class="relative group p-6 rounded-4xl bg-secondary shadow-xl shadow-secondary/20 overflow-hidden transition-all active:scale-[0.98] block hover:brightness-110">
                <div class="absolute top-4 right-6 opacity-90">
                    <span class="material-symbols-outlined !text-[64px] text-tertiary" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div class="flex flex-col h-full justify-between relative z-10">
                    <div>
                        <span class="inline-block px-3 py-1 rounded-full bg-white/20 text-white text-[10px] font-black uppercase tracking-widest mb-4 border border-white/10">Completed</span>
                        <h3 class="text-xl font-black text-white mb-2 pr-12 italic">Topic 01: Nouns & Objects</h3>
                        <p class="text-white/80 text-sm mb-6 pr-12">Mastering the building blocks of every sentence in the universe.</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex justify-between items-end text-white">
                            <span class="text-[10px] font-black uppercase tracking-widest opacity-70">Progress</span>
                            <span class="text-sm font-black">100%</span>
                        </div>
                        <div class="h-2 w-full bg-white/20 rounded-full overflow-hidden">
                            <div class="h-full bg-tertiary w-full rounded-full shadow-[0_0_12px_rgba(255,179,0,0.6)]"></div>
                        </div>
                        <div class="w-full mt-4 py-3.5 bg-white text-secondary font-black rounded-full text-center text-sm shadow-md">
                            Review Lesson
                        </div>
                    </div>
                </div>
            </a>

            <div class="relative group p-6 rounded-4xl bg-white border border-primary/5 shadow-sm overflow-hidden transition-all active:scale-[0.98] cursor-pointer">
                <div class="absolute top-4 right-6 flex items-center justify-center">
                    <div class="relative inline-block leading-none">
                        <span class="material-symbols-outlined !text-[64px] text-surface-variant/40" style="font-variation-settings: 'FILL' 1;">star</span>
                        <div class="absolute top-0 left-0 overflow-hidden h-full pointer-events-none" style="width: 65%;">
                            <span class="material-symbols-outlined !text-[64px] text-tertiary" style="font-variation-settings: 'FILL' 1;">star</span>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col h-full justify-between relative z-10">
                    <div>
                        <span class="inline-block px-3 py-1 rounded-full bg-secondary/10 text-secondary text-[10px] font-black uppercase tracking-widest mb-4 border border-secondary/5">In Progress</span>
                        <h3 class="text-xl font-black text-on-surface mb-2 pr-12 italic">Topic 02: Action Verbs</h3>
                        <p class="text-on-surface/60 text-sm mb-6 pr-12 leading-relaxed">Giving life and motion to your stories through powerful verbs.</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex justify-between items-end">
                            <span class="text-on-surface/40 text-[10px] font-black uppercase tracking-widest">Current Orbit</span>
                            <span class="text-secondary text-sm font-black">65%</span>
                        </div>
                        <div class="h-2 w-full bg-surface rounded-full overflow-hidden border border-primary/5">
                            <div class="h-full bg-tertiary w-[65%] rounded-full shadow-[0_0_12px_rgba(255,179,0,0.4)]"></div>
                        </div>
                        <button class="w-full mt-4 py-3.5 bg-secondary text-white font-black rounded-full text-sm shadow-lg shadow-secondary/20">
                            Continue Mission
                        </button>
                    </div>
                </div>
            </div>

            <div class="relative p-6 rounded-4xl bg-surface-variant/30 border border-primary/5 grayscale opacity-60">
                <div class="absolute inset-0 flex flex-col items-center justify-center z-10 pointer-events-none">
                    <div class="bg-white/80 p-3 rounded-full shadow-lg mb-2">
                        <span class="material-symbols-outlined text-on-surface/40 !text-2xl">lock</span>
                    </div>
                    <span class="text-[9px] font-black uppercase text-on-surface/40 tracking-widest">LOCKED</span>
                </div>
                <div class="flex flex-col h-full justify-between blur-[1px]">
                    <div>
                        <span class="inline-block px-3 py-1 rounded-full bg-on-surface/5 text-on-surface/40 text-[10px] font-black uppercase mb-4">Not Started</span>
                        <h3 class="text-xl font-black text-on-surface/40 mb-2 italic">Topic 03: Simple Tenses</h3>
                        <p class="text-on-surface/40 text-sm mb-6 leading-relaxed">Navigating the timelines of past, present, and the future.</p>
                    </div>
                    <button class="w-full mt-4 py-3.5 bg-on-surface/10 text-on-surface/40 font-black rounded-full text-sm cursor-not-allowed uppercase tracking-widest">
                        Locked
                    </button>
                </div>
            </div>
        </div>

        <section class="mt-12 bg-white/60 backdrop-blur-md rounded-4xl p-8 border border-white flex flex-col md:flex-row items-center gap-10 shadow-sm relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-5 pointer-events-none">
                <span class="material-symbols-outlined !text-[150px]">auto_awesome</span>
            </div>
            
            <div class="relative w-32 h-32 flex-shrink-0">
                <svg class="w-full h-full transform -rotate-90">
                    <circle class="text-surface" cx="64" cy="64" fill="transparent" r="58" stroke="currentColor" stroke-width="8"></circle>
                    <circle class="text-tertiary" cx="64" cy="64" fill="transparent" r="58" stroke="currentColor" stroke-width="10" stroke-dasharray="364.4" stroke-dashoffset="182.2" stroke-linecap="round"></circle>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span class="text-2xl font-black text-on-surface leading-none">50%</span>
                    <span class="text-[10px] font-black text-on-surface/40 uppercase tracking-tighter">Overall</span>
                </div>
            </div>

            <div class="text-center md:text-left flex-grow space-y-4">
                <h4 class="text-xl font-black text-on-surface italic tracking-tight uppercase">Stellar progress!</h4>
                <p class="text-on-surface/60 text-sm font-medium leading-relaxed">
                    You've completed <span class="text-secondary font-black uppercase">1 OUT OF 2</span> topics.
                </p>
                <div class="flex flex-wrap gap-3 justify-center md:justify-start">
                    <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-sm border border-primary/5 text-xs font-black uppercase text-on-surface/70">
                        <span class="material-symbols-outlined !text-lg text-primary" style="font-variation-settings: 'FILL' 1;">stars</span>
                        12 Stars
                    </div>
                </div>
            </div>
        </section>
    </main>
</MainLayout>