---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/card.astro';
---

<MainLayout title="Topics">
        <div class="absolute top-20 right-10 opacity-20 pointer-events-none select-none">
            <span class="material-symbols-outlined !text-4xl text-tertiary" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>
        <div class="absolute bottom-40 left-5 opacity-10 scale-150 pointer-events-none select-none">
            <span class="material-symbols-outlined !text-6xl text-primary">rocket_launch</span>
        </div>

        <section class="mb-10">
            <div class="bg-primary text-white p-10 rounded-[48px] relative overflow-hidden shadow-2xl shadow-primary/20 group">
                <div class="relative z-10">
                    <h2 class="text-4xl font-black mb-3 leading-tight italic uppercase tracking-tight">Your Learning<br/>Universe</h2>
                    <p class="text-on-primary opacity-90 text-sm max-w-md font-medium italic leading-relaxed">
                        Embark on your journey through the grammar galaxies. Every star earned brings you closer to mastery!
                    </p>
                </div>
                
                <div class="absolute -top-4 -right-4 text-tertiary opacity-30 transform rotate-12 transition-transform group-hover:rotate-45 duration-700">
                    <span class="material-symbols-outlined !text-[120px]" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                </div>
                <div class="absolute -bottom-6 right-6 w-40 h-40 opacity-20 pointer-events-none">
                    <span class="material-symbols-outlined !text-[160px] text-white">rocket_launch</span>
                </div>
            </div>
        </section>

        <div class="flex items-center justify-between mb-8 px-4">
            <h3 class="text-xl font-black text-on-surface tracking-tight uppercase italic">Learning Modules</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <Card 
                variant="red"
                href="/subtopics"
                badgeText="Topic 01"
                title="Nouns & Objects"
                description="Mastering the building blocks of every sentence in the universe."
                progress="100"
                iconName="star"
            />

            <Card 
                variant="white"
                href="/verbs"
                badgeText="Topic 02"
                title="Action Verbs"
                description="Giving life and motion to your stories through powerful verbs."
                progress="20"
                iconName="star"
            />

            <Card 
                variant="gray"
                badgeText="Topic 03"
                title="Sentence Building"
                description="Unlock this module by completing the previous journey."
                iconName="lock"
            />

        </div>

        <div class="mt-16 flex justify-center gap-4">
            <div class="w-3 h-3 rounded-full bg-tertiary shadow-[0_0_10px_rgba(254,179,0,0.5)]"></div>
            <div class="w-3 h-3 rounded-full bg-primary/40"></div>
            <div class="w-3 h-3 rounded-full bg-secondary/40"></div>
        </div>
</MainLayout>