---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/card.astro';
import '../styles/topics.css';
---

<MainLayout title="Topics">

    <section class="universe-banner group hover:shadow-primary/40">
        
        <!-- Ulduz -->
        <div class="bg-decor-star">
            <span class="material-symbols-outlined !text-4xl text-tertiary">star</span>
        </div>

        <!-- Raket -->
        <div class="bg-decor-rocket">
            <span class="material-symbols-outlined !text-6xl text-primary">rocket_launch</span>
        </div>

        <div class="relative z-10">
            <h2 class="universe-title">Your Learning<br/>Universe</h2>
            <p class="universe-text">
                Embark on your journey through the grammar galaxies. Every star earned brings you closer to mastery!
            </p>
        </div>
        
        <div class="banner-icon-magic group-hover:rotate-45 group-hover:scale-110">
            <span class="material-symbols-outlined !text-[140px] md:!text-[180px]">auto_awesome</span>
        </div>
        
        <div class="banner-icon-rocket group-hover:translate-x-4 group-hover:-translate-y-4 transition-transform duration-1000">
            <span class="material-symbols-outlined !text-[180px] md:!text-[220px] text-white">rocket_launch</span>
        </div>
    </section>

    <!-- BURANI SİLDİK -->
    <!--
    <div class="module-header">
        <h3 class="module-title">Learning Modules</h3>
    </div>
    -->

    <div class="modules-grid">
        <Card 
            variant="red"
            href="/subtopics"
            badgeText="Topic 01"
            title="Nouns & Objects"
            description="Mastering the building blocks of every sentence in the universe."
            progress="100"
            iconName="star"
        />

        <Card 
            variant="white"
            href="/verbs"
            badgeText="Topic 02"
            title="Action Verbs"
            description="Giving life and motion to your stories through powerful verbs."
            progress="20"
            iconName="star"
        />

        <Card 
            variant="gray"
            badgeText="Topic 03"
            title="Sentence Building"
            description="Unlock this module by completing the previous journey."
            iconName="lock"
        />
    </div>

    <div class="pagination-container">
        <div class="dot dot-active"></div>
        <div class="dot dot-inactive"></div>
        <div class="dot dot-inactive"></div>
    </div>

</MainLayout>