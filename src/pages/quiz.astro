---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/quiz.css';

---

<MainLayout title="Practice Quiz" isUserLoggedIn={true}>
        
    <section class="quiz-banner group">
        <div class="absolute -top-10 -right-10 text-white opacity-10 transform transition-transform duration-1000 group-hover:rotate-45">
            <span class="material-symbols-outlined !text-[180px]">star</span>
        </div>
        
        <div class="relative z-10 space-y-6">
            <span class="quiz-banner-badge">Practice Quiz</span>
            <h2 class="quiz-banner-title">Countable & Uncountable Nouns</h2>
            
            <div class="space-y-3">
                <div class="flex justify-between items-end text-[10px] font-black uppercase tracking-widest opacity-80">
                    <span>Mission Status</span>
                    <span>Step 4 of 5</span>
                </div>
                <div class="h-3 w-full bg-white/20 rounded-full overflow-hidden border border-white/10 p-0.5">
                    <div class="w-[80%] h-full bg-[#feb300] rounded-full shadow-[0_0_15px_rgba(255,179,0,0.6)]"></div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-10 px-4">
        <div class="question-container">
            <h3 class="question-text">
                Which of these is <span class="text-[#af101a] underline decoration-4 underline-offset-8">uncountable</span>?
            </h3>
            
            <div class="grid gap-4 md:gap-5">
                <button class="option-btn option-active">
                    <span class="option-letter-box bg-white/20 border border-white/20 text-white">A</span>
                    <span class="font-black text-lg flex-1 uppercase tracking-wide">Water</span>
                    <span class="material-symbols-outlined !text-3xl">check_circle</span>
                </button>

                <button class="option-btn option-default">
                    <span class="option-letter-box bg-white text-[#155f98] shadow-sm border border-slate-100">B</span>
                    <span class="font-black text-lg flex-1 uppercase tracking-wide opacity-70">Apple</span>
                </button>

                <button class="option-btn option-default">
                    <span class="option-letter-box bg-white text-[#155f98] shadow-sm border border-slate-100">C</span>
                    <span class="font-black text-lg flex-1 uppercase tracking-wide opacity-70">Book</span>
                </button>
            </div>
        </div>
    </section>

    <section class="px-4">
        <div class="quiz-feedback-card">
            <div class="text-center space-y-2">
                <h4 class="text-2xl font-black text-[#213041] uppercase tracking-tight">Rate this Lesson</h4>
                <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest">How was your learning journey today?</p>
            </div>

            <div class="flex justify-center gap-4">
                {[1, 2, 3, 4, 5].map((i) => (
                    <button class="text-[#feb300] transition-all hover:scale-125 active:scale-75">
                        <span class="material-symbols-outlined !text-[44px]">star</span>
                    </button>
                ))}
            </div>

            <div class="space-y-4">
                <label class="text-[11px] font-black text-[#155f98] uppercase tracking-widest px-2">Tell Teacher Roya nəyi bəyəndin?</label>
                <textarea 
                    class="feedback-textarea" 
                    placeholder="Your message from across the galaxy..."
                ></textarea>
            </div>

            <button id="submit-quiz-btn" class="w-full py-5 md:py-6 bg-[#af101a] text-white rounded-full font-black text-base shadow-xl shadow-red-900/20 active:scale-95 transition-all flex items-center justify-center gap-4 uppercase tracking-widest">
                Submit & Finish
                <span class="material-symbols-outlined !text-2xl">rocket_launch</span>
            </button>
        </div>
    </section>

</MainLayout>

<script>
    const submitBtn = document.getElementById('submit-quiz-btn');
    
    if (submitBtn) {
        submitBtn.addEventListener('click', () => {
            // Bir az gecikmə əlavə etmək olar ki, düymənin "active" effekti görünsün
            setTimeout(() => {
                window.location.href = '/examresult';
            }, 200);
        });
    }
</script>