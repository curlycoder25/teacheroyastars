---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Practice Quiz" isUserLoggedIn={true}>
        
        <section class="relative overflow-hidden bg-secondary rounded-[48px] p-10 text-white shadow-2xl shadow-secondary/20 group mb-8">
            <div class="absolute -top-10 -right-10 text-white opacity-10 transform rotate-12 pointer-events-none group-hover:rotate-45 transition-transform duration-1000">
                <span class="material-symbols-outlined !text-[180px]" style="font-variation-settings: 'FILL' 1;">star</span>
            </div>
            
            <div class="relative z-10 space-y-6">
                <span class="inline-block px-4 py-1.5 bg-white/20 backdrop-blur-md rounded-full text-[10px] font-black uppercase tracking-widest border border-white/10 italic">Practice Quiz</span>
                <h2 class="text-3xl font-black italic tracking-tight leading-tight uppercase">Countable & Uncountable Nouns</h2>
                
                <div class="space-y-3">
                    <div class="flex justify-between items-end text-[10px] font-black uppercase tracking-widest opacity-80 italic">
                        <span>Mission Status</span>
                        <span>Step 4 of 5</span>
                    </div>
                    <div class="h-3.5 w-full bg-white/20 rounded-full overflow-hidden border border-white/10 shadow-inner p-1">
                        <div class="w-[80%] h-full bg-[#feb300] rounded-full shadow-[0_0_15px_rgba(255,179,0,0.6)] animate-pulse transition-all duration-700"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="space-y-6 mb-10">
            <div class="bg-white rounded-[40px] p-10 shadow-xl shadow-[#155f98]/5 border border-primary/5 space-y-10">
                <h3 class="text-2xl font-black text-[#213041] leading-snug italic uppercase tracking-tight pr-4">
                    Which of these is <span class="text-secondary underline decoration-4 underline-offset-8">uncountable</span>?
                </h3>
                
                <div class="grid gap-5">
                    <button class="flex items-center p-6 rounded-[32px] bg-primary text-white ring-8 ring-primary/5 transition-all duration-300 group active:scale-[0.98] text-left shadow-lg shadow-primary/20">
                        <span class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/20 font-black mr-5 text-sm border border-white/20">A</span>
                        <span class="font-black text-lg flex-1 italic uppercase tracking-wide">Water</span>
                        <span class="material-symbols-outlined !text-3xl filled-icon" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    </button>

                    <button class="flex items-center p-6 rounded-[32px] bg-[#f3f6ff] text-[#213041] hover:bg-white hover:shadow-md transition-all duration-300 group active:scale-[0.98] text-left border border-primary/5">
                        <span class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white font-black mr-5 text-sm text-primary shadow-sm border border-primary/5">B</span>
                        <span class="font-black text-lg flex-1 italic uppercase tracking-wide opacity-70">Apple</span>
                    </button>

                    <button class="flex items-center p-6 rounded-[32px] bg-[#f3f6ff] text-[#213041] hover:bg-white hover:shadow-md transition-all duration-300 group active:scale-[0.98] text-left border border-primary/5">
                        <span class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white font-black mr-5 text-sm text-primary shadow-sm border border-primary/5">C</span>
                        <span class="font-black text-lg flex-1 italic uppercase tracking-wide opacity-70">Book</span>
                    </button>
                </div>
            </div>
        </section>

        <section class="bg-white rounded-[40px] p-10 border border-primary/5 shadow-xl shadow-[#155f98]/5 space-y-10 relative overflow-hidden mb-20">
            <div class="text-center space-y-3">
                <h4 class="text-2xl font-black text-[#213041] italic uppercase tracking-tight">Rate this Lesson</h4>
                <p class="text-[10px] text-[#213041]/40 font-black uppercase tracking-[0.2em]">How was your learning journey today?</p>
            </div>

            <div class="flex justify-center gap-4">
                {[1, 2, 3, 4, 5].map((i) => (
                    <button class="text-[#feb300] transition-all hover:scale-125 active:scale-75">
                        <span class="material-symbols-outlined !text-[44px] filled-icon" style="font-variation-settings: 'FILL' 1;">star</span>
                    </button>
                ))}
            </div>

            <div class="space-y-4">
                <label class="text-[11px] font-black text-[#155f98] uppercase tracking-[0.15em] px-2 italic">Tell Teacher Roya what you liked</label>
                <textarea 
                    class="w-full bg-[#f3f6ff] border-none rounded-[32px] p-7 text-base text-[#213041] placeholder:text-[#213041]/30 focus:ring-4 focus:ring-[#83bdfd]/30 min-h-[160px] transition-all font-medium shadow-inner italic outline-none" 
                    placeholder="Your message from across the galaxy..."
                ></textarea>
            </div>

            <button class="w-full py-6 bg-secondary text-white rounded-full font-black text-base shadow-2xl shadow-secondary/30 active:scale-95 transition-all flex items-center justify-center gap-4 uppercase tracking-[0.2em] italic">
                Submit & Finish
                <span class="material-symbols-outlined !text-2xl">rocket_launch</span>
            </button>
        </section>
</MainLayout>