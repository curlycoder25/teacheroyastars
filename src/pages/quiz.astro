---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/quiz.css';
---

<MainLayout title="Practice Quiz" isUserLoggedIn={true}>
    <!-- 'pink-mode' class-ı CSS-dəki dəyişənləri işə salır (Pink rejim üçün) -->
    <div class="theme-pink min-h-screen pb-20">
        
        <!-- Quiz Banner: Yığcam ölçülər -->
        <section class="theme-banner relative overflow-hidden p-8 md:p-12 text-white shadow-xl mb-10 group">
            <div class="absolute -top-10 -right-10 text-white opacity-10 transform transition-transform duration-1000 group-hover:rotate-45 pointer-events-none">
                <span class="material-symbols-outlined !text-[12rem]">star</span>
            </div>
            
            <div class="relative z-10 space-y-6 max-w-4xl mx-auto">
                <span class="bg-white/20 backdrop-blur-md px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-white/10 inline-block">Practice Quiz</span>
                <h2 class="text-3xl md:text-5xl font-black tracking-tighter uppercase italic leading-none">Countable & Uncountable</h2>
                
                <div class="space-y-3 max-w-xs">
                    <div class="flex justify-between items-end text-[10px] font-black uppercase tracking-widest opacity-80">
                        <span>Mission Status</span>
                        <span>Step 4 of 5</span>
                    </div>
                    <div class="h-2.5 w-full bg-white/20 rounded-full overflow-hidden border border-white/5 p-0.5">
                        <div class="w-[80%] h-full bg-tertiary rounded-full shadow-[0_0_12px_rgb(var(--tertiary)/0.6)]"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Question Section: px ölçüləri Tailwind standartlarına keçdi -->
        <section class="max-w-4xl mx-auto px-6 mb-10">
            <div class="bg-surface-container-lowest border-2 border-surface-container-high p-8 md:p-12 rounded-xl shadow-xl shadow-on-surface/5">
                <h3 class="text-xl md:text-3xl font-black text-on-surface uppercase tracking-tight italic mb-10 leading-tight">
                    Which of these is <span class="text-secondary underline decoration-4 underline-offset-8">uncountable</span>?
                </h3>
                
                <div class="grid gap-4 md:gap-5">
                    <!-- Active/Selected Option (Dinamik Rəngli) -->
                    <button class="theme-option-btn theme-option-active group">
                        <span class="w-10 h-10 rounded-lg bg-primary/20 border border-white/20 text-white flex items-center justify-center font-black">A</span>
                        <span class="font-black text-base md:text-lg flex-1 uppercase tracking-wide italic">Water</span>
                        <span class="material-symbols-outlined !text-3xl">check_circle</span>
                    </button>

                    <!-- Default Options -->
                    <button class="theme-option-btn group">
                        <span class="w-10 h-10 rounded-lg bg-surface border border-surface-container-high text-primary flex items-center justify-center font-black group-hover:bg-white transition-colors shadow-sm">B</span>
                        <span class="font-black text-base md:text-lg flex-1 uppercase tracking-wide opacity-50 italic group-hover:opacity-100 transition-opacity">Apple</span>
                    </button>

                    <button class="theme-option-btn group">
                        <span class="w-10 h-10 rounded-lg bg-surface border border-surface-container-high text-primary flex items-center justify-center font-black group-hover:bg-white transition-colors shadow-sm">C</span>
                        <span class="font-black text-base md:text-lg flex-1 uppercase tracking-wide opacity-50 italic group-hover:opacity-100 transition-opacity">Book</span>
                    </button>
                </div>
            </div>
        </section>

        <!-- Feedback & Submit Section -->
        <section class="max-w-2xl mx-auto px-6">
            <div class="bg-surface border-2 border-dashed border-surface-container-high p-10 rounded-xl space-y-10">
                <div class="text-center space-y-2">
                    <h4 class="text-2xl font-black text-on-surface uppercase tracking-tight italic">Rate this Lesson</h4>
                    <p class="text-[10px] text-on-surface-variant font-black uppercase tracking-[0.2em]">How was your learning journey today?</p>
                </div>

                <!-- SARI ULDUZLAR (Tam Dolu) -->
                <div class="flex justify-center gap-4">
                    {[1, 2, 3, 4, 5].map((i) => (
                        <button class="text-tertiary transition-all hover:scale-125 active:scale-75" type="button">
                            <span class="material-symbols-outlined !text-5xl star-filled">star</span>
                        </button>
                    ))}
                </div>

                <div class="space-y-4">
                    <label class="text-xs font-black text-primary uppercase tracking-widest px-2 italic">Tell Teacher Roya nəyi bəyəndin?</label>
                    <textarea 
                        class="w-full bg-surface-container-lowest border-2 border-surface-container-high rounded-lg p-6 text-on-surface placeholder:text-on-surface-variant/30 focus:bg-white transition-all outline-none min-h-[140px] text-sm font-bold italic" 
                        placeholder="Your message from across the galaxy..."
                    ></textarea>
                </div>

                <button id="submit-quiz-btn" class="bg-secondary w-full py-5 md:py-6 text-white rounded-full font-black text-sm shadow-xl shadow-secondary/20 active:scale-95 transition-all flex items-center justify-center gap-4 uppercase tracking-[0.2em] italic">
                    Submit & Finish
                    <span class="material-symbols-outlined !text-2xl">rocket_launch</span>
                </button>
            </div>
        </section>
    </div>
</MainLayout>

<script>
    const submitBtn = document.getElementById('submit-quiz-btn');
    
    if (submitBtn) {
        submitBtn.addEventListener('click', () => {
            // Düymə effekti üçün qısa gecikmə ilə yönləndirmə
            setTimeout(() => {
                window.location.href = '/examresult';
            }, 200);
        });
    }
</script>