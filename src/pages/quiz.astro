---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Practice Quiz">
    <main class="pt-24 pb-32 px-6 max-w-xl mx-auto space-y-8">
        
        <section class="relative overflow-hidden bg-secondary rounded-4xl p-8 text-white shadow-2xl shadow-secondary/20 group">
            <div class="absolute -top-6 -right-6 text-white opacity-10 transform rotate-12 pointer-events-none">
                <span class="material-symbols-outlined !text-[120px]" style="font-variation-settings: 'FILL' 1;">star</span>
            </div>
            
            <div class="relative z-10 space-y-4">
                <span class="inline-block px-3 py-1 bg-white/20 backdrop-blur-md rounded-full text-[10px] font-black uppercase tracking-widest border border-white/10">Practice Quiz</span>
                <h2 class="text-2xl font-black italic tracking-tight leading-tight">Countable & Uncountable Nouns</h2>
                
                <div class="space-y-2">
                    <div class="flex justify-between items-end text-[10px] font-black uppercase tracking-widest opacity-80">
                        <span>Mission Status</span>
                        <span>Step 4 of 5</span>
                    </div>
                    <div class="h-2.5 w-full bg-white/20 rounded-full overflow-hidden border border-white/10 shadow-inner">
                        <div class="w-[80%] h-full bg-tertiary rounded-full shadow-[0_0_15px_rgba(255,179,0,0.6)] animate-pulse"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="space-y-6">
            <div class="bg-white rounded-4xl p-8 shadow-sm border border-primary/5 space-y-8">
                <h3 class="text-xl font-black text-on-surface leading-snug italic">Which of these is <span class="text-secondary underline decoration-2 underline-offset-4">uncountable</span>?</h3>
                
                <div class="grid gap-4">
                    <button class="flex items-center p-5 rounded-3xl bg-primary text-white ring-4 ring-primary/10 transition-all duration-300 group active:scale-[0.98] text-left">
                        <span class="w-10 h-10 flex items-center justify-center rounded-2xl bg-white/20 font-black mr-4 text-sm border border-white/20">A</span>
                        <span class="font-bold text-base flex-1">Water</span>
                        <span class="material-symbols-outlined !text-2xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    </button>

                    <button class="flex items-center p-5 rounded-3xl bg-surface text-on-surface hover:bg-surface-container-high transition-all duration-300 group active:scale-[0.98] text-left border border-primary/5">
                        <span class="w-10 h-10 flex items-center justify-center rounded-2xl bg-white font-black mr-4 text-sm text-primary shadow-sm">B</span>
                        <span class="font-bold text-base flex-1">Apple</span>
                    </button>

                    <button class="flex items-center p-5 rounded-3xl bg-surface text-on-surface hover:bg-surface-container-high transition-all duration-300 group active:scale-[0.98] text-left border border-primary/5">
                        <span class="w-10 h-10 flex items-center justify-center rounded-2xl bg-white font-black mr-4 text-sm text-primary shadow-sm">C</span>
                        <span class="font-bold text-base flex-1">Book</span>
                    </button>
                </div>
            </div>
        </section>

        <section class="bg-white rounded-4xl p-8 border border-primary/5 shadow-sm space-y-8 relative overflow-hidden">
            <div class="text-center space-y-2">
                <h4 class="text-lg font-black text-on-surface italic">Rate this Lesson</h4>
                <p class="text-xs text-on-surface/50 font-black uppercase tracking-widest">How was your learning journey today?</p>
            </div>

            <div class="flex justify-center gap-3">
                {[1, 2, 3, 4, 5].map((i) => (
                    <button class="text-tertiary transition-transform active:scale-75">
                        <span class="material-symbols-outlined !text-4xl" style="font-variation-settings: 'FILL' 1;">star</span>
                    </button>
                ))}
            </div>

            <div class="space-y-3">
                <label class="text-[10px] font-black text-primary uppercase tracking-widest px-1">Tell Teacher Roya what you liked</label>
                <textarea 
                    class="w-full bg-surface border-none rounded-3xl p-5 text-sm text-on-surface placeholder:text-on-surface/30 focus:ring-2 focus:ring-primary min-h-[120px] transition-all font-medium shadow-inner" 
                    placeholder="Your message from across the galaxy..."
                ></textarea>
            </div>

            <button class="w-full py-5 bg-secondary text-white rounded-full font-black text-base shadow-xl shadow-secondary/20 active:scale-95 transition-all flex items-center justify-center gap-3 uppercase tracking-widest">
                Submit & Finish
                <span class="material-symbols-outlined">rocket_launch</span>
            </button>
        </section>
    </main>
</MainLayout>