---
import MainLayout from '../layouts/MainLayout.astro';
import SuccessModal from '../components/SuccessModal.astro';
import '../styles/lesson.css';
---

<MainLayout title="Lesson: Countable & Uncountable">
    <div class="theme-pink min-h-screen pb-20">
        
        <header class="max-w-5xl mx-auto pt-8 px-6 mb-8">
            <div class="flex flex-wrap items-center gap-3 mb-6">
                <a href="/subtopics" class="p-2 bg-surface-container-lowest rounded-full shadow-sm border border-surface-container-high text-primary active:scale-95 transition-all flex items-center justify-center">
                    <span class="material-symbols-outlined !text-base">arrow_back</span>
                </a>
                <span class="text-xs font-black uppercase tracking-widest text-primary bg-primary/10 px-4 py-1 rounded-full border border-primary/10">Grammar Focus</span>
                <span class="material-symbols-outlined text-tertiary !text-base">star</span>
            </div>
            <h2 class="text-3xl md:text-5xl font-black text-on-surface tracking-tighter uppercase italic leading-none mb-3">Countable & Uncountable Nouns</h2>
            <p class="text-on-surface-variant font-bold text-sm italic opacity-70">Master the art of measuring things in English.</p>
        </header>

        <section class="max-w-5xl mx-auto px-6 mb-12">
            <div class="video-container group relative aspect-video rounded-xl overflow-hidden shadow-xl border-4 border-surface-container-lowest bg-surface">
                <div class="absolute inset-0 bg-on-surface/40 group-hover:bg-on-surface/20 transition-all duration-700 z-10"></div>
                <img 
                    src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&q=80&w=1200" 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" 
                    alt="Lesson Video"
                />
                
                <div class="absolute inset-0 flex flex-col items-center justify-center z-20">
                    <button class="bg-primary w-16 h-16 rounded-full flex items-center justify-center shadow-2xl group-hover:scale-110 transition-all">
                        <span class="material-symbols-outlined !text-3xl text-white">play_arrow</span>
                    </button>
                    <div class="mt-6 text-center text-white">
                        <h3 class="font-black text-xl uppercase tracking-tight italic">Main Video Explanation</h3>
                        <p class="text-white/80 text-[10px] font-black uppercase tracking-widest mt-3 bg-black/30 backdrop-blur-md px-5 py-2 rounded-full inline-block border border-white/10 italic">12 minutes • Teacher Roya</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto px-6 mb-16">
            <section class="bg-surface-container-lowest border-2 border-surface-container-high p-8 rounded-lg shadow-sm group relative overflow-hidden">
                <div class="absolute -top-8 -right-8 opacity-5 group-hover:rotate-12 transition-transform duration-500">
                    <span class="material-symbols-outlined !text-9xl">description</span>
                </div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-lg bg-primary/10 flex items-center justify-center mb-6 shadow-inner">
                        <span class="material-symbols-outlined text-primary !text-2xl">picture_as_pdf</span>
                    </div>
                    <h3 class="text-xl font-black text-on-surface mb-3 uppercase italic">Lesson Notes</h3>
                    <p class="text-on-surface-variant text-sm mb-10 leading-relaxed font-medium italic">Download the comprehensive guide including examples of 'How many' vs 'How much'.</p>
                    <button class="bg-primary w-full py-5 text-white rounded-full font-black text-xs flex items-center justify-center gap-3 active:scale-95 transition-all shadow-lg italic uppercase tracking-widest">
                        Read Notes <span class="material-symbols-outlined !text-lg">open_in_new</span>
                    </button>
                </div>
            </section>

            <section class="bg-surface border-2 border-dashed border-surface-container-high p-8 rounded-lg group flex flex-col justify-between">
                <div class="flex items-start justify-between mb-8">
                    <div class="w-14 h-14 rounded-lg bg-surface-container-lowest flex items-center justify-center shadow-md">
                        <span class="material-symbols-outlined text-secondary !text-3xl">smart_display</span>
                    </div>
                    <span class="text-[10px] font-black uppercase text-secondary tracking-widest bg-surface-container-lowest px-5 py-2 rounded-full border border-secondary/10 shadow-sm">Extra Learning</span>
                </div>
                
                <div class="flex gap-4 mb-10 bg-surface-container-lowest p-5 rounded-lg border border-surface-container-high shadow-sm active:scale-95 transition-transform cursor-pointer group-hover:border-secondary/20">
                    <div class="w-16 h-14 rounded-lg bg-secondary/10 shrink-0 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-secondary !text-2xl">movie_filter</span>
                    </div>
                    <div>
                        <h4 class="font-black text-sm text-on-surface uppercase italic">Common Mistakes</h4>
                        <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mt-1">Real-world examples</p>
                    </div>
                </div>

                <a class="text-secondary font-black text-xs flex items-center gap-2 hover:underline uppercase tracking-widest group no-underline italic" href="#">
                    Watch on YouTube <span class="material-symbols-outlined !text-xl group-hover:translate-x-3 transition-transform">arrow_forward</span>
                </a>
            </section>
        </div>

        <section class="max-w-5xl mx-auto px-6 mb-20">
            <div class="bg-primary relative overflow-hidden rounded-xl p-12 md:p-20 text-white text-center shadow-2xl group">
                <div class="absolute -top-16 -left-16 opacity-10 transform -rotate-12 pointer-events-none">
                    <span class="material-symbols-outlined !text-[12rem] text-white">auto_awesome</span>
                </div>
                
                <div class="relative z-10 space-y-8">
                    <h3 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tighter leading-none italic">Ready to test knowledge?</h3>
                    <p class="text-white/80 max-w-xl mx-auto font-medium text-sm md:text-lg leading-relaxed italic">Take the 5-minute quiz to earn your <span class="text-tertiary font-black underline decoration-4 underline-offset-8 italic">"Noun Master"</span> star.</p>
                    
                    <a href="/quiz" class="inline-flex items-center gap-3 bg-surface-container-lowest text-on-surface px-12 py-5 rounded-full font-black text-xs uppercase tracking-widest shadow-2xl hover:scale-105 active:scale-95 transition-all no-underline italic">
                        <span class="material-symbols-outlined !text-2xl text-primary">quiz</span> Start Quiz
                    </a>
                </div>
            </div>
        </section>

        <section class="max-w-3xl mx-auto px-6 mb-24">
            <div class="bg-surface-container-lowest rounded-xl p-10 md:p-14 border-2 border-surface-container-high shadow-2xl shadow-on-surface/5 space-y-10">
                <div class="text-center space-y-2">
                    <h4 class="text-2xl md:text-3xl font-black text-on-surface uppercase tracking-tight italic">Rate this Lesson</h4>
                    <p class="text-[10px] text-on-surface-variant font-black uppercase tracking-[0.3em]">How was your learning journey today?</p>
                </div>

                <div class="flex justify-center gap-4">
                    {[1, 2, 3, 4, 5].map((i) => (
                        <button class="text-tertiary transition-all hover:scale-125 active:scale-75" type="button">
                            <span class="material-symbols-outlined !text-5xl star-filled">star</span>
                        </button>
                    ))}
                </div>

                <div class="space-y-4">
                    <label class="text-xs font-black text-primary uppercase tracking-widest px-4">Any thoughts for Teacher Roya?</label>
                    <textarea 
                        class="w-full bg-surface border-2 border-surface-container-high rounded-lg p-8 text-on-surface placeholder:text-on-surface-variant/30 focus:bg-surface-container-lowest transition-all outline-none min-h-[180px] font-bold italic" 
                        placeholder="Share your feedback..."
                    ></textarea>
                </div>

                <button id="submit-review-btn" class="bg-secondary w-full py-6 text-white rounded-full font-black text-sm shadow-xl shadow-secondary/20 active:scale-95 transition-all flex items-center justify-center gap-4 uppercase tracking-widest italic" type="button">
                    Submit Review
                    <span class="material-symbols-outlined !text-3xl">rocket_launch</span>
                </button>
            </div>
        </section>

        <SuccessModal />
    </div>
</MainLayout>

<script>
    const submitBtn = document.getElementById('submit-review-btn');
    const modal = document.getElementById('success-modal');
    const closeBtn = document.getElementById('close-modal');
    const rocket = document.querySelector('#rocket-container span');

    if (submitBtn && modal) {
        submitBtn.addEventListener('click', (e) => {
            e.preventDefault();
            modal.classList.add('show');
        });
    }

    if (closeBtn && modal && rocket) {
        closeBtn.addEventListener('click', () => {
            rocket.classList.add('fly-away');
            setTimeout(() => {
                modal.classList.remove('show');
                window.location.href = '/topics'; 
            }, 800);
        });
    }
</script>