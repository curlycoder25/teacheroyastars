---
import MainLayout from '../layouts/MainLayout.astro';
import SuccessModal from '../components/SuccessModal.astro'; // Modalı import edirik
import '../styles/lesson.css';
---

<MainLayout title="Lesson: Countable & Uncountable">
        
        <header class="lesson-header">
            <div class="flex flex-wrap items-center gap-3 mb-6">
                <a href="/subtopics" class="p-2.5 bg-white rounded-full shadow-sm border border-slate-100 text-primary active:scale-90 transition-all flex items-center justify-center">
                    <span class="material-symbols-outlined !text-xl">arrow_back</span>
                </a>
                <span class="text-[10px] font-black uppercase tracking-widest text-primary bg-primary/5 px-4 py-1.5 rounded-full border border-primary/10">Grammar Focus</span>
                <span class="material-symbols-outlined text-[#feb300] !text-xl">star</span>
            </div>
            <h2 class="lesson-title">Countable & Uncountable Nouns</h2>
            <p class="lesson-subtitle">Master the art of measuring things in English.</p>
        </header>

        <section class="video-wrapper">
            <div class="video-container group">
                <div class="video-overlay group-hover:scale-105"></div>
                
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <button class="video-play-btn group-hover:scale-110">
                        <span class="material-symbols-outlined !text-4xl">play_arrow</span>
                    </button>
                    <div class="mt-6 text-center text-white relative z-10">
                        <h3 class="font-black text-xl uppercase tracking-tight">Main Video Explanation</h3>
                        <p class="text-white/70 text-[9px] font-black uppercase tracking-widest mt-2 bg-black/20 px-4 py-1.5 rounded-full inline-block">12 minutes • Teacher Roya</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="lesson-grid">
            <section class="lesson-card bg-white group">
                <div class="absolute -top-6 -right-6 opacity-5 group-hover:rotate-12 transition-transform duration-500">
                    <span class="material-symbols-outlined !text-[120px]">description</span>
                </div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center mb-6 shadow-inner">
                        <span class="material-symbols-outlined text-[#155f98] !text-2xl">picture_as_pdf</span>
                    </div>
                    <h3 class="text-xl font-black text-slate-800 mb-2 uppercase">Lesson Notes</h3>
                    <p class="text-slate-500 text-sm mb-10 leading-relaxed font-medium pr-4">Download the comprehensive guide including examples of 'How many' vs 'How much'.</p>
                    <button class="w-full py-4 bg-[#155f98] text-white rounded-full font-black text-[10px] flex items-center justify-center gap-2 active:scale-95 transition-all shadow-lg shadow-blue-900/20 uppercase tracking-widest">
                        Read Notes <span class="material-symbols-outlined !text-lg">open_in_new</span>
                    </button>
                </div>
            </section>

            <section class="lesson-card bg-slate-50 shadow-inner group">
                <div class="flex items-start justify-between mb-8">
                    <div class="w-14 h-14 rounded-2xl bg-white flex items-center justify-center shadow-sm">
                        <span class="material-symbols-outlined text-[#af101a] !text-2xl">smart_display</span>
                    </div>
                    <span class="text-[9px] font-black uppercase text-[#af101a] tracking-widest bg-white px-4 py-2 rounded-full border border-red-100 shadow-sm">Extra Learning</span>
                </div>
                
                <div class="flex gap-4 mb-10 bg-white p-4 rounded-2xl border border-slate-100 shadow-sm active:scale-95 transition-transform cursor-pointer">
                    <div class="w-16 h-12 rounded-xl bg-red-50 flex-shrink-0 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-[#af101a] !text-2xl">movie_filter</span>
                    </div>
                    <div>
                        <h4 class="font-black text-sm text-slate-800 uppercase">Common Mistakes</h4>
                        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-1">Real-world examples</p>
                    </div>
                </div>

                <a class="text-[#af101a] font-black text-[10px] flex items-center gap-2 hover:underline uppercase tracking-widest group no-underline" href="#">
                    Watch on YouTube <span class="material-symbols-outlined !text-lg group-hover:translate-x-2 transition-transform">arrow_forward</span>
                </a>
            </section>
        </div>

        <div class="progress-container">
            <div class="flex justify-between items-center mb-5 px-2">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Course Progress</span>
                <span class="text-xs font-black text-primary">65% COMPLETED</span>
            </div>
            <div class="h-3 w-full bg-slate-100 rounded-full overflow-hidden p-0.5 border border-slate-200">
                <div class="h-full w-[65%] bg-[#feb300] rounded-full shadow-[0_0_10px_rgba(255,179,0,0.4)]"></div>
            </div>
        </div>

        <section class="quiz-section mb-12">
            <div class="quiz-banner group">
                <div class="absolute -top-16 -left-16 opacity-10 transform -rotate-12 transition-transform group-hover:rotate-0 duration-1000">
                    <span class="material-symbols-outlined !text-[12rem] text-white">auto_awesome</span>
                </div>
                
                <div class="relative z-10 space-y-6">
                    <h3 class="text-2xl md:text-4xl font-black text-white uppercase tracking-tight leading-tight">Ready to test your knowledge?</h3>
                    <p class="text-white/80 max-w-md mx-auto font-medium text-sm md:text-base leading-relaxed pr-2">Take the 5-minute quiz to earn your <span class="text-[#feb300] font-black">"Noun Master"</span> star.</p>
                    
                    <a href="/quiz" class="quiz-btn hover:scale-105">
                        <span class="material-symbols-outlined !text-2xl">quiz</span> Start Quiz
                    </a>
                </div>
            </div>
        </section>

        <section class="max-w-[1200px] mx-auto px-4 mb-24">
            <div class="bg-white rounded-[40px] p-10 border border-slate-100 shadow-xl shadow-blue-900/5 space-y-10 relative overflow-hidden">
                <div class="text-center space-y-2">
                    <h4 class="text-2xl font-black text-[#213041] uppercase tracking-tight">Rate this Lesson</h4>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest">How was your learning journey today?</p>
                </div>

                <div class="flex justify-center gap-4">
                    {[1, 2, 3, 4, 5].map((i) => (
                        <button class="text-[#feb300] transition-all hover:scale-125 active:scale-75">
                            <span class="material-symbols-outlined !text-[44px]">star</span>
                        </button>
                    ))}
                </div>

                <div class="space-y-4">
                    <label class="text-[11px] font-black text-[#155f98] uppercase tracking-widest px-2">Any thoughts for Teacher Roya?</label>
                    <textarea 
                        class="w-full bg-slate-50 border-none rounded-[24px] p-7 text-[#213041] placeholder:text-slate-300 focus:ring-4 focus:ring-blue-100 min-h-[160px] transition-all outline-none" 
                        placeholder="Share your feedback..."
                    ></textarea>
                </div>

                <button id="submit-review-btn" class="w-full py-5 bg-[#af101a] text-white rounded-full font-black text-base shadow-xl shadow-red-900/20 active:scale-95 transition-all flex items-center justify-center gap-4 uppercase tracking-widest">
                    Submit Review
                    <span class="material-symbols-outlined !text-2xl">rocket_launch</span>
                </button>
            </div>
        </section>

        <SuccessModal />

</MainLayout>

<script>
    const submitBtn = document.getElementById('submit-review-btn');
    const modal = document.getElementById('success-modal');
    const closeBtn = document.getElementById('close-modal');
    const rocket = document.querySelector('#rocket-container span');

    if (submitBtn && modal) {
        submitBtn.addEventListener('click', (e) => {
            e.preventDefault();
            modal.classList.add('show');
        });
    }

    if (closeBtn && modal && rocket) {
        closeBtn.addEventListener('click', () => {
            rocket.classList.add('fly-away');
            setTimeout(() => {
                modal.classList.remove('show');
                window.location.href = '/topics'; 
            }, 800);
        });
    }
</script>