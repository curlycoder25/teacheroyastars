---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Lesson: Countable & Uncountable">
    <main class="pt-24 pb-32 px-6 max-w-4xl mx-auto relative overflow-hidden">
        
        <header class="mb-8">
            <div class="flex items-center gap-2 mb-3">
                <a href="/subtopics" class="p-2 bg-white rounded-full shadow-sm border border-primary/5 text-primary active:scale-90 transition-all mr-2">
                    <span class="material-symbols-outlined flex items-center justify-center">arrow_back</span>
                </a>
                <span class="text-[10px] font-black uppercase tracking-widest text-primary bg-primary/5 px-3 py-1 rounded-full border border-primary/10">Grammar Focus</span>
                <span class="material-symbols-outlined text-tertiary !text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
            </div>
            <h2 class="text-3xl font-black text-on-surface leading-tight tracking-tight italic">Countable & Uncountable Nouns</h2>
            <p class="text-on-surface/60 mt-2 text-lg font-medium">Master the art of measuring things in English.</p>
        </header>

        <section class="mb-10">
            <div class="group relative aspect-video w-full rounded-4xl bg-secondary overflow-hidden shadow-2xl shadow-secondary/10 border-4 border-white">
                <div class="absolute inset-0 bg-gradient-to-br from-secondary to-secondary-dim opacity-90 transition-transform duration-700 group-hover:scale-105"></div>
                
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <button class="w-20 h-20 rounded-full bg-white text-secondary flex items-center justify-center shadow-2xl active:scale-90 transition-all duration-200 group-hover:scale-110">
                        <span class="material-symbols-outlined !text-4xl" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
                    </button>
                    <div class="mt-6 text-center text-white relative z-10">
                        <h3 class="font-black text-xl italic tracking-tight">Main Video Explanation</h3>
                        <p class="text-white/80 text-xs font-bold uppercase tracking-widest mt-1">12 minutes • Teacher Roya</p>
                    </div>
                </div>
                
                <div class="absolute bottom-0 left-0 w-full h-1/3 bg-gradient-to-t from-black/40 to-transparent pointer-events-none"></div>
            </div>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
            
            <section class="bg-white p-8 rounded-4xl relative overflow-hidden group border border-primary/5 shadow-sm">
                <div class="absolute -top-4 -right-4 opacity-5 group-hover:rotate-12 transition-transform duration-500">
                    <span class="material-symbols-outlined !text-[120px] text-primary">description</span>
                </div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-primary/5 flex items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-primary !text-3xl">picture_as_pdf</span>
                    </div>
                    <h3 class="text-xl font-black text-on-surface mb-2 italic">Lesson Notes</h3>
                    <p class="text-on-surface/60 text-sm mb-8 leading-relaxed font-medium">Download the comprehensive guide including examples of 'How many' vs 'How much'.</p>
                    <button class="w-full py-4 px-6 bg-primary text-white rounded-full font-black text-sm flex items-center justify-center gap-2 active:scale-95 transition-all shadow-lg shadow-primary/20 uppercase tracking-widest">
                        Read Notes
                        <span class="material-symbols-outlined !text-sm">open_in_new</span>
                    </button>
                </div>
            </section>

            <section class="bg-surface p-8 rounded-4xl relative overflow-hidden group border border-primary/5 shadow-inner">
                <div class="flex items-start justify-between mb-6">
                    <div class="w-14 h-14 rounded-2xl bg-secondary/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-secondary !text-3xl">smart_display</span>
                    </div>
                    <span class="text-[9px] font-black uppercase text-secondary tracking-widest bg-secondary/10 px-3 py-1.5 rounded-full border border-secondary/10">Extra Learning</span>
                </div>
                
                <div class="flex gap-4 mb-8 bg-white p-4 rounded-3xl border border-primary/5 shadow-sm">
                    <div class="w-20 h-14 rounded-xl bg-secondary/20 flex-shrink-0 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-secondary">movie_filter</span>
                    </div>
                    <div>
                        <h4 class="font-black text-sm text-on-surface italic">Common Mistakes</h4>
                        <p class="text-[10px] font-black uppercase tracking-widest text-on-surface/40 mt-1">Real-world examples</p>
                    </div>
                </div>

                <a class="text-secondary font-black text-xs flex items-center gap-2 hover:underline uppercase tracking-widest group" href="#">
                    Watch on YouTube
                    <span class="material-symbols-outlined !text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </a>
            </section>
        </div>

        <div class="bg-white p-8 rounded-4xl mb-10 border border-primary/5 shadow-sm">
            <div class="flex justify-between items-center mb-4">
                <span class="text-xs font-black text-on-surface uppercase tracking-widest opacity-40">Course Progress</span>
                <span class="text-sm font-black text-primary">65%</span>
            </div>
            <div class="h-3 w-full bg-surface rounded-full overflow-hidden border border-primary/5 shadow-inner">
                <div class="h-full w-[65%] bg-tertiary rounded-full relative shadow-[0_0_15px_rgba(255,179,0,0.5)]">
                    <div class="absolute inset-0 bg-white/20 animate-pulse"></div>
                </div>
            </div>
        </div>

        <section class="mb-20">
            <div class="bg-secondary rounded-4xl p-10 text-center relative overflow-hidden shadow-2xl shadow-secondary/20 group">
                <div class="absolute -top-10 -left-10 opacity-20 transform -rotate-12 transition-transform group-hover:rotate-0 duration-700">
                    <span class="material-symbols-outlined !text-[12rem] text-white" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                </div>
                
                <div class="relative z-10 space-y-6">
                    <h3 class="text-2xl md:text-3xl font-black text-white italic tracking-tight leading-tight">Ready to test your knowledge?</h3>
                    <p class="text-white/80 mb-8 max-w-md mx-auto font-medium text-sm leading-relaxed">Take the 5-minute quiz to earn your <span class="text-tertiary font-black">"Noun Master"</span> star and unlock the next lesson.</p>
                    
                    <a href="/quiz" class="w-full max-w-sm py-5 px-8 bg-white text-secondary rounded-full text-lg font-black shadow-2xl active:scale-95 transition-all flex items-center justify-center gap-3 mx-auto uppercase tracking-widest group-hover:scale-105">
                        <span class="material-symbols-outlined !text-2xl" style="font-variation-settings: 'FILL' 1;">quiz</span>
                        Start Practice Quiz
                    </a>
                    
                    <p class="text-white/40 text-[9px] font-black uppercase tracking-widest mt-4 flex items-center justify-center gap-1">
                        <span class="material-symbols-outlined !text-sm">verified</span>
                        Verified by Teacher Roya
                    </p>
                </div>
            </div>
        </section>
    </main>
</MainLayout>