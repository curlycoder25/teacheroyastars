---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Lesson: Countable & Uncountable" isUserLoggedIn={true}>
        
        <header class="mb-8 px-2">
            <div class="flex items-center gap-2 mb-4">
                <a href="/subtopics" class="p-3 bg-white rounded-full shadow-sm border border-primary/5 text-primary active:scale-90 transition-all mr-2 flex items-center justify-center">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
                <span class="text-[10px] font-black uppercase tracking-widest text-primary bg-primary/5 px-4 py-1.5 rounded-full border border-primary/10 italic">Grammar Focus</span>
                <span class="material-symbols-outlined text-[#feb300] !text-xl" style="font-variation-settings: 'FILL' 1;">star</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-black text-[#213041] leading-tight tracking-tight italic uppercase">Countable & Uncountable Nouns</h2>
            <p class="text-[#213041]/60 mt-2 text-lg font-medium italic">Master the art of measuring things in English.</p>
        </header>

        <section class="mb-10">
            <div class="group relative aspect-video w-full rounded-[48px] bg-secondary overflow-hidden shadow-2xl shadow-secondary/20 border-4 border-white">
                <div class="absolute inset-0 bg-gradient-to-br from-secondary to-[#a40113] opacity-90 transition-transform duration-700 group-hover:scale-105"></div>
                
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <button class="w-24 h-24 rounded-full bg-white text-secondary flex items-center justify-center shadow-2xl active:scale-90 transition-all duration-300 group-hover:scale-110">
                        <span class="material-symbols-outlined !text-5xl" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
                    </button>
                    <div class="mt-6 text-center text-white relative z-10">
                        <h3 class="font-black text-2xl italic tracking-tight uppercase">Main Video Explanation</h3>
                        <p class="text-white/80 text-[10px] font-black uppercase tracking-widest mt-2 bg-black/10 px-4 py-1 rounded-full inline-block">12 minutes • Teacher Roya</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
            
            <section class="bg-white p-10 rounded-[40px] relative overflow-hidden group border border-primary/5 shadow-md">
                <div class="absolute -top-6 -right-6 opacity-5 group-hover:rotate-12 transition-transform duration-500">
                    <span class="material-symbols-outlined !text-[150px] text-primary">description</span>
                </div>
                <div class="relative z-10">
                    <div class="w-16 h-16 rounded-[24px] bg-[#f3f6ff] flex items-center justify-center mb-6 shadow-inner">
                        <span class="material-symbols-outlined text-primary !text-3xl">picture_as_pdf</span>
                    </div>
                    <h3 class="text-2xl font-black text-[#213041] mb-2 italic uppercase">Lesson Notes</h3>
                    <p class="text-[#213041]/60 text-sm mb-10 leading-relaxed font-medium italic pr-4">Download the comprehensive guide including examples of 'How many' vs 'How much'.</p>
                    <button class="w-full py-5 px-6 bg-primary text-white rounded-full font-black text-xs flex items-center justify-center gap-2 active:scale-95 transition-all shadow-lg shadow-primary/20 uppercase tracking-widest">
                        Read Notes
                        <span class="material-symbols-outlined !text-lg">open_in_new</span>
                    </button>
                </div>
            </section>

            <section class="bg-[#f3f6ff] p-10 rounded-[40px] relative overflow-hidden group border border-primary/5 shadow-inner">
                <div class="flex items-start justify-between mb-8">
                    <div class="w-16 h-16 rounded-[24px] bg-white flex items-center justify-center shadow-sm">
                        <span class="material-symbols-outlined text-secondary !text-3xl">smart_display</span>
                    </div>
                    <span class="text-[9px] font-black uppercase text-secondary tracking-widest bg-white px-4 py-2 rounded-full border border-secondary/10 shadow-sm italic">Extra Learning</span>
                </div>
                
                <div class="flex gap-5 mb-10 bg-white p-5 rounded-[28px] border border-primary/5 shadow-sm active:scale-95 transition-transform cursor-pointer">
                    <div class="w-20 h-16 rounded-2xl bg-secondary/10 flex-shrink-0 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-secondary !text-3xl">movie_filter</span>
                    </div>
                    <div>
                        <h4 class="font-black text-sm text-[#213041] italic uppercase">Common Mistakes</h4>
                        <p class="text-[9px] font-black uppercase tracking-widest text-[#213041]/40 mt-1 italic">Real-world examples</p>
                    </div>
                </div>

                <a class="text-secondary font-black text-xs flex items-center gap-2 hover:underline uppercase tracking-[0.2em] group no-underline italic" href="#">
                    Watch on YouTube
                    <span class="material-symbols-outlined !text-xl group-hover:translate-x-2 transition-transform">arrow_forward</span>
                </a>
            </section>
        </div>

        <div class="bg-white p-8 rounded-[40px] mb-10 border border-primary/5 shadow-sm">
            <div class="flex justify-between items-center mb-5 px-2">
                <span class="text-[10px] font-black text-[#213041]/40 uppercase tracking-[0.2em] italic text-center">Course Progress</span>
                <span class="text-sm font-black text-primary italic">65% COMPLETED</span>
            </div>
            <div class="h-4 w-full bg-[#f3f6ff] rounded-full overflow-hidden border border-primary/5 shadow-inner p-1">
                <div class="h-full w-[65%] bg-[#feb300] rounded-full relative shadow-[0_0_15px_rgba(255,179,0,0.6)]">
                    <div class="absolute inset-0 bg-white/30 animate-pulse"></div>
                </div>
            </div>
        </div>

        <section class="mb-20 px-2">
            <div class="bg-secondary rounded-[48px] p-12 text-center relative overflow-hidden shadow-2xl shadow-secondary/30 group">
                <div class="absolute -top-16 -left-16 opacity-20 transform -rotate-12 transition-transform group-hover:rotate-0 duration-1000">
                    <span class="material-symbols-outlined !text-[16rem] text-white" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                </div>
                
                <div class="relative z-10 space-y-8">
                    <h3 class="text-3xl md:text-4xl font-black text-white italic tracking-tight leading-tight uppercase">Ready to test your knowledge?</h3>
                    <p class="text-white/80 max-w-md mx-auto font-medium text-base leading-relaxed italic pr-2">Take the 5-minute quiz to earn your <span class="text-[#feb300] font-black italic">"Noun Master"</span> star and unlock the next galaxy.</p>
                    
                    <a href="/quiz" class="w-full max-w-sm py-6 px-10 bg-white text-secondary rounded-full text-lg font-black shadow-2xl active:scale-95 transition-all flex items-center justify-center gap-4 mx-auto uppercase tracking-[0.15em] group-hover:scale-105 no-underline">
                        <span class="material-symbols-outlined !text-3xl filled-icon" style="font-variation-settings: 'FILL' 1;">quiz</span>
                        Start Quiz
                    </a>
                </div>
            </div>
        </section>
</MainLayout>