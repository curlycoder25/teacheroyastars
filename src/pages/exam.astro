---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Stellar Examinations">
    <main class="pt-24 pb-32 px-6 max-w-4xl mx-auto relative overflow-hidden">
        
        <section class="mb-10 text-center relative">
            <div class="absolute -top-10 -right-4 opacity-20 pointer-events-none select-none">
                <span class="material-symbols-outlined !text-6xl text-tertiary" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-black text-on-surface tracking-tight mb-2 italic uppercase">
                Stellar Examinations
            </h2>
            <p class="text-on-surface/60 font-medium text-sm">Choose your mission and test your cosmic knowledge.</p>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <button class="group relative flex flex-col text-left overflow-hidden bg-secondary rounded-4xl transition-all active:scale-[0.98] md:col-span-2 shadow-xl shadow-secondary/20 border-4 border-white">
                <div class="p-10 relative z-10 flex flex-col h-full w-full">
                    <div class="flex justify-between items-start mb-8">
                        <div class="bg-white/20 backdrop-blur-md p-5 rounded-full border border-white/20">
                            <span class="material-symbols-outlined text-white !text-4xl flex items-center justify-center">rocket_launch</span>
                        </div>
                        <span class="bg-tertiary text-on-tertiary-container text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-full shadow-lg">Most Popular</span>
                    </div>
                    
                    <h3 class="text-3xl font-black text-white mb-2 italic tracking-tight">Grade 9 Exam</h3>
                    <p class="text-white/80 text-sm max-w-md mb-8 leading-relaxed font-medium">
                        Master the foundations of the ninth galaxy. Complete all 12 modules to earn your Bronze Star.
                    </p>
                    
                    <div class="mt-auto flex items-center gap-6">
                        <div class="flex-1 h-3 bg-white/20 rounded-full overflow-hidden border border-white/10 shadow-inner">
                            <div class="h-full bg-tertiary w-[65%] rounded-full shadow-[0_0_15px_rgba(255,179,0,0.6)]"></div>
                        </div>
                        <span class="text-white text-xs font-black uppercase tracking-widest whitespace-nowrap">65% Readiness</span>
                    </div>
                </div>

                <div class="absolute top-4 right-4 text-white/10 select-none pointer-events-none">
                    <span class="material-symbols-outlined !text-[220px] leading-none" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div class="absolute inset-0 bg-gradient-to-br from-secondary to-secondary-dim -z-10"></div>
            </button>

            <button class="group flex flex-col text-left bg-white rounded-4xl p-8 border border-primary/5 shadow-sm transition-all active:scale-95 grayscale opacity-70">
                <div class="bg-primary/5 p-4 rounded-3xl self-start mb-6 border border-primary/5">
                    <span class="material-symbols-outlined text-primary !text-3xl flex items-center justify-center">satellite</span>
                </div>
                <h3 class="text-xl font-black text-on-surface mb-2 italic tracking-tight">Grade 11 Exam</h3>
                <p class="text-on-surface/50 text-xs mb-8 leading-relaxed font-medium">Advanced navigation through linguistic nebulas and complex grammar systems.</p>
                
                <div class="mt-auto flex justify-between items-center bg-surface p-3 rounded-2xl border border-primary/5">
                    <span class="text-[10px] font-black text-on-surface/40 uppercase tracking-widest">Locked</span>
                    <span class="material-symbols-outlined text-on-surface/40 !text-xl">lock</span>
                </div>
            </button>

            <button class="group flex flex-col text-left bg-white rounded-4xl p-8 border border-primary/5 shadow-sm transition-all active:scale-95 hover:shadow-md">
                <div class="bg-tertiary/10 p-4 rounded-3xl self-start mb-6 border border-tertiary/10">
                    <span class="material-symbols-outlined text-tertiary !text-3xl flex items-center justify-center">menu_book</span>
                </div>
                <h3 class="text-xl font-black text-on-surface mb-2 italic tracking-tight">General Grammar</h3>
                <p class="text-on-surface/60 text-xs mb-8 leading-relaxed font-medium">Explore the universal laws of language that govern all stellar communication.</p>
                
                <div class="mt-auto flex justify-between items-center bg-primary/5 p-3 rounded-2xl border border-primary/5">
                    <span class="text-[10px] font-black text-primary uppercase tracking-widest">42 Lessons</span>
                    <span class="material-symbols-outlined text-primary !text-xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </div>
            </button>
        </div>

        <div class="mt-12 p-10 rounded-4xl bg-white border-4 border-dashed border-primary/10 flex flex-col md:flex-row items-center gap-8 relative overflow-hidden group">
            <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            
            <div class="relative">
                <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-white shadow-2xl relative z-10">
                    <img alt="Nebula View" class="w-full h-full object-cover scale-110 group-hover:scale-125 transition-transform duration-700" src="/api/placeholder/100/100"/>
                </div>
                <div class="absolute -bottom-2 -right-2 bg-tertiary text-white rounded-full p-2.5 shadow-xl z-20 border-2 border-white">
                    <span class="material-symbols-outlined !text-xl flex items-center justify-center" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
                </div>
            </div>
            
            <div class="text-center md:text-left flex-1 relative z-10 space-y-2">
                <h4 class="font-black text-xl text-on-surface italic">Star Commander Track</h4>
                <p class="text-on-surface/60 text-sm font-medium leading-relaxed">Earn your wings by completing all exam categories with a score above 90%.</p>
            </div>
            
            <button class="bg-primary text-white px-8 py-4 rounded-full font-black text-sm uppercase tracking-widest active:scale-90 transition-transform shadow-lg shadow-primary/20 relative z-10">
                View Rewards
            </button>
        </div>
    </main>
</MainLayout>