---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/card.astro';
import '../styles/exam.css';
---

<MainLayout title="Stellar Examinations">
    
    <section class="exam-header">
        <div class="exam-header-icon">
            <span class="material-symbols-outlined !text-5xl text-tertiary">auto_awesome</span>
        </div>
        <h2 class="exam-title">Stellar Examinations</h2>
        <p class="exam-subtitle">Choose your mission and test your cosmic knowledge.</p>
    </section>

    <div class="exam-grid">
        <Card 
            variant="red"
            href="/9grade"
            badgeText="Most Popular"
            title="Grade 9 Exam"
            description="Master the foundations of the ninth galaxy. Complete all 12 modules to earn your Bronze Star."
            progress="65"
            iconName="rocket_launch"
            class="md:col-span-2" 
        />
        
        <Card 
            variant="gray"
            badgeText="Advanced"
            title="Grade 11 Exam"
            description="Advanced navigation through linguistic nebulas and complex grammar systems."
            iconName="satellite"
        />

        <Card 
            variant="white"
            href="/topics"
            badgeText="42 Lessons"
            title="General Grammar"
            description="Explore the universal laws of language that govern all stellar communication."
            iconName="menu_book"
        >
            <div slot="action-button" class="w-full bg-primary text-white py-4 rounded-full font-black uppercase text-[10px] tracking-widest text-center">
                Explore Universe
            </div>
        </Card>
    </div>

    <div class="reward-card group">
        <div class="reward-card-hover-bg group-hover:opacity-100"></div>
        
        <div class="reward-image-wrapper">
            <div class="reward-img-circle">
                <img alt="Nebula View" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" src="/api/placeholder/100/100"/>
            </div>
            <div class="reward-badge">
                <span class="material-symbols-outlined !text-xl flex items-center justify-center">workspace_premium</span>
            </div>
        </div>
        
        <div class="reward-content">
            <h4 class="reward-title">Star Commander Track</h4>
            <p class="reward-text">Earn your wings by completing all exam categories with a score above 90%.</p>
        </div>
        
        <button class="btn-reward">
            View Rewards
        </button>
    </div>
</MainLayout>