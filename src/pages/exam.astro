---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/card.astro'; // Komponenti mütləq import edirik
---

<MainLayout title="Stellar Examinations">
    
    <section class="mb-10 text-center relative">
        <div class="absolute -top-10 -right-4 opacity-20 pointer-events-none select-none">
            <span class="material-symbols-outlined !text-6xl text-tertiary" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-black text-on-surface tracking-tight mb-2 italic uppercase">
            Stellar Examinations
        </h2>
        <p class="text-on-surface/60 font-medium text-sm italic">Choose your mission and test your cosmic knowledge.</p>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        <Card 
            variant="red"
            href="/9grade"
            badgeText="Most Popular"
            title="Grade 9 Exam"
            description="Master the foundations of the ninth galaxy. Complete all 12 modules to earn your Bronze Star."
            progress="65"
            iconName="rocket_launch"
            class="md:col-span-2" 
        />
        <Card 
            variant="gray"
            badgeText="Advanced"
            title="Grade 11 Exam"
            description="Advanced navigation through linguistic nebulas and complex grammar systems."
            iconName="satellite"
        />

        <Card 
            variant="white"
            href="/topics"
            badgeText="42 Lessons"
            title="General Grammar"
            description="Explore the universal laws of language that govern all stellar communication."
            iconName="menu_book"
        >
            <div slot="action-button" class="w-full bg-primary text-white py-4 rounded-full font-black uppercase text-[10px] tracking-widest text-center">
                Explore Universe
            </div>
        </Card>
    </div>

    <div class="mt-12 p-10 rounded-[48px] bg-white border-4 border-dashed border-primary/10 flex flex-col md:flex-row items-center gap-8 relative overflow-hidden group">
        <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="relative">
            <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-white shadow-2xl relative z-10">
                <img alt="Nebula View" class="w-full h-full object-cover scale-110 group-hover:scale-125 transition-transform duration-700" src="/api/placeholder/100/100"/>
            </div>
            <div class="absolute -bottom-2 -right-2 bg-tertiary text-white rounded-full p-2.5 shadow-xl z-20 border-2 border-white">
                <span class="material-symbols-outlined !text-xl flex items-center justify-center" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
            </div>
        </div>
        
        <div class="text-center md:text-left flex-1 relative z-10 space-y-2">
            <h4 class="font-black text-xl text-on-surface italic uppercase">Star Commander Track</h4>
            <p class="text-on-surface/60 text-sm font-medium leading-relaxed italic">Earn your wings by completing all exam categories with a score above 90%.</p>
        </div>
        
        <button class="bg-primary text-white px-8 py-4 rounded-full font-black text-xs uppercase tracking-widest active:scale-90 transition-transform shadow-lg shadow-primary/20 relative z-10">
            View Rewards
        </button>
    </div>
</MainLayout>