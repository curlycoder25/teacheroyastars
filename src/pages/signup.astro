---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Sign Up" isIndex={true}>
    <div class="fixed top-0 left-0 w-full h-full pointer-events-none overflow-hidden -z-20">
        <div class="absolute top-[10%] right-[15%] text-tertiary/10">
            <span class="material-symbols-outlined !text-9xl rotate-12 flex items-center justify-center" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
        </div>
        <div class="absolute bottom-[5%] left-[5%] text-accent/10">
            <span class="material-symbols-outlined !text-[12rem] -rotate-12 flex items-center justify-center">cloud</span>
        </div>
    </div>

    <main class="pt-24 pb-32 px-6 flex flex-col items-center justify-center min-h-screen relative overflow-hidden">
        
        <div class="absolute top-20 -left-10 w-40 h-40 bg-white/40 blur-3xl rounded-full -z-10"></div>
        <div class="absolute bottom-40 -right-10 w-64 h-64 bg-accent/20 blur-3xl rounded-full -z-10"></div>
        
        <div class="absolute top-32 right-10 text-tertiary opacity-40 select-none animate-pulse">
            <span class="material-symbols-outlined !text-4xl flex items-center justify-center" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>
        <div class="absolute top-60 left-12 text-tertiary opacity-20 select-none">
            <span class="material-symbols-outlined !text-2xl flex items-center justify-center" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>

        <div class="w-full max-w-md bg-white rounded-4xl p-8 shadow-[0_20px_50px_rgba(72,133,193,0.08)] relative z-10 border border-white/40">
            <div class="text-center mb-8">
                <h1 class="text-2xl font-black tracking-tight text-on-surface mb-2">Join the Galaxy</h1>
                <p class="text-on-surface-variant text-sm font-medium opacity-70">Start your celestial learning journey today.</p>
            </div>

            <form class="space-y-5">
                <div class="space-y-1.5">
                    <label class="text-[11px] font-black uppercase tracking-widest text-primary ml-1">Full Name</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-outline-variant text-lg flex items-center justify-center">person</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-surface border-none rounded-2xl focus:ring-2 focus:ring-accent text-on-surface font-bold outline-none transition-all placeholder:text-outline-variant/60 text-sm" placeholder="Enter your full name" type="text" value="Jalə Əzimli"/>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[11px] font-black uppercase tracking-widest text-primary ml-1">Phone Number</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-outline-variant text-lg flex items-center justify-center">call</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-surface border-none rounded-2xl focus:ring-2 focus:ring-accent text-on-surface font-bold outline-none transition-all placeholder:text-outline-variant/60 text-sm" placeholder="Enter phone number" type="tel" value="+994 50 315 39 45"/>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[11px] font-black uppercase tracking-widest text-primary ml-1">Email Address</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-outline-variant text-lg flex items-center justify-center">mail</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-surface border-none rounded-2xl focus:ring-2 focus:ring-accent text-on-surface font-bold outline-none transition-all placeholder:text-outline-variant/60 text-sm" placeholder="Enter your email" type="email" value="your.star@email.com"/>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[11px] font-black uppercase tracking-widest text-primary ml-1">Secure Password</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-outline-variant text-lg flex items-center justify-center">lock</span>
                        <input class="w-full pl-12 pr-12 py-4 bg-surface border-none rounded-2xl focus:ring-2 focus:ring-accent text-on-surface font-bold outline-none transition-all text-sm" placeholder="Create a password" type="password" value="••••••••"/>
                        <button class="absolute right-4 text-outline-variant hover:text-primary transition-colors flex items-center justify-center" type="button">
                            <span class="material-symbols-outlined text-lg">visibility_off</span>
                        </button>
                    </div>
                </div>

                <button class="w-full bg-secondary text-white py-4 mt-2 rounded-full font-black text-base shadow-lg shadow-secondary/20 active:scale-95 transition-all flex items-center justify-center gap-2" type="submit">
                    Sign Up
                    <span class="material-symbols-outlined flex items-center justify-center">arrow_forward</span>
                </button>
            </form>

            <div class="mt-8 text-center">
                <p class="text-sm text-on-surface-variant font-medium">
                    Already have an account? 
                    <a class="font-black text-secondary hover:underline ml-1" href="/login">Log In</a>
                </p>
            </div>
        </div>

        <div class="mt-10 flex items-center gap-8 opacity-50">
            <div class="flex flex-col items-center gap-2">
                <div class="bg-accent/20 p-3 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">verified_user</span>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest text-on-surface">Secure SSL</span>
            </div>
            <div class="flex flex-col items-center gap-2">
                <div class="bg-accent/20 p-3 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">school</span>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest text-on-surface">Expert Tutors</span>
            </div>
        </div>
    </main>
</MainLayout>