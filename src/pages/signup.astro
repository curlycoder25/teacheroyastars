---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/signup.css';
---

<MainLayout title="Sign Up" isIndex={true} hideHeader={true} hideNavbar={true}>
    
    <div class="signup-bg-decor">
        <div class="absolute top-[10%] right-[15%] text-[#feb300]/10">
            <span class="material-symbols-outlined !text-9xl rotate-12">auto_awesome</span>
        </div>
        <div class="absolute bottom-[5%] left-[5%] text-[#83bdfd]/10">
            <span class="material-symbols-outlined !text-[160px] -rotate-12">cloud</span>
        </div>
    </div>

    <section class="signup-section">
        <div class="signup-card">
            <div class="text-center mb-10">
                <h1 class="signup-title">Join the Galaxy</h1>
                <p class="signup-subtitle">Start your celestial learning journey today.</p>
            </div>

            <form class="space-y-5">
                <div class="signup-form-group">
                    <label class="signup-label">Full Name</label>
                    <input class="signup-input" placeholder="Enter your full name" type="text" />
                </div>

                <div class="signup-form-group">
                    <label class="signup-label">Phone Number</label>
                    <input class="signup-input" placeholder="+994" type="tel" />
                </div>

                <div class="signup-form-group">
                    <label class="signup-label">Email Address</label>
                    <input class="signup-input" placeholder="your@email.com" type="email" />
                </div>

                <div class="signup-form-group">
                    <label class="signup-label">Secure Password</label>
                    <div class="relative flex items-center">
                        <input class="signup-input pr-12" placeholder="••••••••" type="password" />
                        <button class="absolute right-4 text-slate-400 hover:text-primary transition-colors" type="button">
                            <span class="material-symbols-outlined !text-lg">visibility_off</span>
                        </button>
                    </div>
                </div>

                <button class="btn-signup" type="submit">
                    Sign Up Now
                    <span class="material-symbols-outlined !text-xl">arrow_forward</span>
                </button>
            </form>

            <div class="mt-8 text-center">
                <p class="text-sm text-slate-400 font-medium">
                    Already have an account? 
                    <a class="font-black text-[#af101a] hover:underline ml-1 uppercase text-xs" href="/login">Log In</a>
                </p>
            </div>
        </div>
    </section>
</MainLayout>