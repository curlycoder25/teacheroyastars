---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/card.astro'; // Komponenti import edirik
---

<MainLayout title="Sign Up" isIndex={true} hideHeader={true} hideNavbar={true}>
    <div class="fixed top-0 left-0 w-full h-full pointer-events-none overflow-hidden -z-20">
        <div class="absolute top-[10%] right-[15%] text-[#feb300]/10">
            <span class="material-symbols-outlined !text-9xl rotate-12" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
        </div>
        <div class="absolute bottom-[5%] left-[5%] text-[#83bdfd]/10">
            <span class="material-symbols-outlined !text-[12rem] -rotate-12">cloud</span>
        </div>
    </div>

    <section class="flex flex-col items-center justify-center min-h-[80vh] relative">
        
        <div class="absolute top-0 -left-10 w-40 h-40 bg-white/40 blur-3xl rounded-full -z-10"></div>
        <div class="absolute bottom-10 -right-10 w-64 h-64 bg-[#83bdfd]/20 blur-3xl rounded-full -z-10"></div>
        
        <div class="absolute top-10 right-0 text-[#feb300] opacity-40 animate-pulse">
            <span class="material-symbols-outlined !text-4xl" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>

        <div class="w-full max-w-md bg-white rounded-[48px] p-10 shadow-2xl shadow-[#155f98]/5 border border-white/40">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-black tracking-tight text-[#213041] mb-2 uppercase italic">Join the Galaxy</h1>
                <p class="text-[#213041]/50 text-sm font-medium italic">Start your celestial learning journey today.</p>
            </div>

            <form class="space-y-5">
                <div class="space-y-1.5">
                    <label class="text-[10px] font-black uppercase tracking-widest text-[#155f98] ml-2">Full Name</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#69788c] text-lg">person</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-2 focus:ring-[#83bdfd] text-[#213041] font-bold outline-none transition-all placeholder:text-[#69788c]/40 text-sm" placeholder="Enter your full name" type="text" />
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-black uppercase tracking-widest text-[#155f98] ml-2">Phone Number</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#69788c] text-lg">call</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-2 focus:ring-[#83bdfd] text-[#213041] font-bold outline-none transition-all placeholder:text-[#69788c]/40 text-sm" placeholder="+994" type="tel" />
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-black uppercase tracking-widest text-[#155f98] ml-2">Email Address</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#69788c] text-lg">mail</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-2 focus:ring-[#83bdfd] text-[#213041] font-bold outline-none transition-all placeholder:text-[#69788c]/40 text-sm" placeholder="your@email.com" type="email" />
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-black uppercase tracking-widest text-[#155f98] ml-2">Secure Password</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#69788c] text-lg">lock</span>
                        <input class="w-full pl-12 pr-12 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-2 focus:ring-[#83bdfd] text-[#213041] font-bold outline-none transition-all text-sm" placeholder="••••••••" type="password" />
                        <button class="absolute right-4 text-[#69788c] hover:text-[#155f98]" type="button">
                            <span class="material-symbols-outlined text-lg">visibility_off</span>
                        </button>
                    </div>
                </div>

                <button class="w-full bg-[#b5161e] text-white py-5 mt-4 rounded-full font-black text-sm uppercase tracking-widest shadow-xl shadow-[#b5161e]/20 active:scale-95 transition-all flex items-center justify-center gap-2" type="submit">
                    Sign Up Now
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </form>

            <div class="mt-8 text-center">
                <p class="text-sm text-[#213041]/60 font-medium italic">
                    Already have an account? 
                    <a class="font-black text-[#b5161e] hover:underline ml-1 uppercase" href="/login">Log In</a>
                </p>
            </div>
        </div>

        <div class="mt-10 flex items-center gap-10 opacity-40 grayscale">
            <div class="flex flex-col items-center gap-2">
                <span class="material-symbols-outlined text-[#155f98]">verified_user</span>
                <span class="text-[9px] font-black uppercase tracking-widest">Secure SSL</span>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="material-symbols-outlined text-[#155f98]">school</span>
                <span class="text-[9px] font-black uppercase tracking-widest">Expert Tutors</span>
            </div>
        </div>
    </section>
</MainLayout>