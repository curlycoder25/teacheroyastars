---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Sign Up" hideHeader={true}>
    <header class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md flex items-center justify-between px-6 py-4 border-b border-[#d1e4ff]">
        <div class="text-xl font-extrabold tracking-tight">
            <span class="text-[#155f98]">Teacher </span>
            <span class="text-[#b5161e]">Roya’s</span> 
            <span class="text-[#155f98]">Stars✨</span>
        </div>
        <button class="text-[#155f98] material-symbols-outlined">close</button>
    </header>

    <main class="pt-24 pb-32 px-6 flex flex-col items-center justify-center min-h-screen relative overflow-hidden">
        
        <div class="absolute top-20 -left-10 w-40 h-40 bg-white/40 blur-3xl rounded-full -z-10"></div>
        <div class="absolute bottom-40 -right-10 w-64 h-64 bg-[#d1e4ff]/30 blur-3xl rounded-full -z-10"></div>
        
        <div class="absolute top-32 right-10 text-[#feb300] opacity-40 select-none animate-pulse">
            <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>
        <div class="absolute top-60 left-12 text-[#feb300] opacity-20 select-none">
            <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;">star</span>
        </div>

        <div class="w-full max-w-md bg-white rounded-3xl p-8 shadow-[0_20px_50px_rgba(72,133,193,0.08)] relative z-10 border border-white/40">
            <div class="text-center mb-8">
                <h1 class="text-2xl font-extrabold tracking-tight text-[#213041] mb-2">Join the Galaxy</h1>
                <p class="text-[#4e5d6f] text-sm font-medium opacity-70">Start your celestial learning journey today.</p>
            </div>

            <form class="space-y-5">
                <div class="space-y-1.5">
                    <label class="text-[11px] font-bold uppercase tracking-widest text-[#155f98] ml-1">Full Name</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#9faec4] text-lg">person</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-2 focus:ring-[#83bdfd] text-[#213041] font-semibold outline-none transition-all placeholder:text-[#9faec4]/60" placeholder="Enter your full name" type="text" value="Jalə Əzimli"/>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[11px] font-bold uppercase tracking-widest text-[#155f98] ml-1">Phone Number</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#9faec4] text-lg">call</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-2 focus:ring-[#83bdfd] text-[#213041] font-semibold outline-none transition-all placeholder:text-[#9faec4]/60" placeholder="Enter phone number" type="tel" value="+994 50 315 39 45"/>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[11px] font-bold uppercase tracking-widest text-[#155f98] ml-1">Email Address</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#9faec4] text-lg">mail</span>
                        <input class="w-full pl-12 pr-4 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-2 focus:ring-[#83bdfd] text-[#213041] font-semibold outline-none transition-all placeholder:text-[#9faec4]/60" placeholder="Enter your email" type="email" value="your.star@email.com"/>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[11px] font-bold uppercase tracking-widest text-[#155f98] ml-1">Secure Password</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#9faec4] text-lg">lock</span>
                        <input class="w-full pl-12 pr-12 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-2 focus:ring-[#83bdfd] text-[#213041] font-semibold outline-none transition-all" placeholder="Create a password" type="password" value="••••••••"/>
                        <button class="absolute right-4 text-[#9faec4] hover:text-[#155f98] transition-colors" type="button">
                            <span class="material-symbols-outlined text-lg">visibility_off</span>
                        </button>
                    </div>
                </div>

                <button class="w-full bg-[#b5161e] text-white py-4 mt-2 rounded-full font-bold text-base shadow-lg shadow-[#b5161e]/20 active:scale-95 transition-all flex items-center justify-center gap-2" type="submit">
                    Sign Up
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </form>

            <div class="mt-8 text-center">
                <p class="text-sm text-[#4e5d6f]">
                    Already have an account? 
                    <a class="font-bold text-[#b5161e] hover:underline" href="/login">Log In</a>
                </p>
            </div>
        </div>

        <div class="mt-10 flex items-center gap-8 opacity-50">
            <div class="flex flex-col items-center">
                <div class="bg-[#d1e4ff] p-3 rounded-full mb-2">
                    <span class="material-symbols-outlined text-[#155f98]">verified_user</span>
                </div>
                <span class="text-[10px] font-bold uppercase tracking-widest text-[#213041]">Secure SSL</span>
            </div>
            <div class="flex flex-col items-center">
                <div class="bg-[#d1e4ff] p-3 rounded-full mb-2">
                    <span class="material-symbols-outlined text-[#155f98]">school</span>
                </div>
                <span class="text-[10px] font-bold uppercase tracking-widest text-[#213041]">Expert Tutors</span>
            </div>
        </div>
    </main>

    <div class="fixed top-0 left-0 w-full h-full pointer-events-none overflow-hidden -z-20">
        <div class="absolute top-[10%] right-[15%] text-[#feb300]/10">
            <span class="material-symbols-outlined text-9xl rotate-12" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
        </div>
        <div class="absolute bottom-[5%] left-[5%] text-[#83bdfd]/10">
            <span class="material-symbols-outlined text-[12rem] -rotate-12">cloud</span>
        </div>
    </div>
</MainLayout>

<style>
    /* Material ikon mərkəzləmə tənzimləməsi */
    .material-symbols-outlined {
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>