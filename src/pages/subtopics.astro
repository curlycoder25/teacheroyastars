---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Nouns - Lessons">
    <main class="pt-24 pb-32 px-6 max-w-2xl mx-auto relative overflow-hidden">
        
        <section class="mb-10 text-center">
            <h2 class="text-3xl font-black text-on-surface mb-2 tracking-tight italic uppercase">Topic 01: Nouns</h2>
            <p class="text-on-surface/60 text-sm font-medium leading-relaxed max-w-xs mx-auto">
                Explore the different types of nouns in our grammar galaxy.
            </p>
        </section>

        <div class="space-y-6">
            
            <div class="relative group overflow-hidden bg-secondary rounded-4xl p-8 shadow-xl shadow-secondary/20 transition-all active:scale-[0.98]">
                <div class="absolute -top-4 -right-4 text-white opacity-20 transform rotate-12 pointer-events-none">
                    <span class="material-symbols-outlined !text-7xl" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                
                <div class="relative z-10 flex flex-col gap-6">
                    <div class="flex justify-between items-start">
                        <div class="bg-white/20 backdrop-blur-sm px-4 py-1.5 rounded-full border border-white/10">
                            <span class="text-[10px] uppercase font-black tracking-widest text-white text-center flex">Lesson 01</span>
                        </div>
                        <span class="material-symbols-outlined text-white !text-2xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    </div>
                    
                    <div>
                        <h3 class="text-2xl font-black text-white mb-1 italic tracking-tight">Compound Nouns</h3>
                        <p class="text-white/70 text-[10px] font-black uppercase tracking-widest">Completed on Oct 12</p>
                    </div>

                    <div class="flex items-center gap-3">
                        <div class="h-2 w-full bg-white/20 rounded-full overflow-hidden">
                            <div class="h-full bg-tertiary w-full shadow-[0_0_12px_rgba(255,179,0,0.6)]"></div>
                        </div>
                        <span class="text-[10px] font-black text-white uppercase tracking-tighter whitespace-nowrap">100%</span>
                    </div>
                </div>
            </div>

            <a href="/lesson" class="relative group bg-white rounded-4xl p-8 shadow-sm border border-primary/5 transition-all active:scale-[0.98] block hover:shadow-lg hover:border-primary/10">
                <div class="absolute -top-4 -right-4 text-tertiary opacity-10 transform rotate-12 pointer-events-none group-hover:opacity-20 transition-opacity">
                    <span class="material-symbols-outlined !text-7xl" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                
                <div class="relative z-10 flex flex-col gap-6">
                    <div class="flex justify-between items-start">
                        <div class="bg-surface px-4 py-1.5 rounded-full border border-primary/5 shadow-sm">
                            <span class="text-[10px] uppercase font-black tracking-widest text-primary text-center flex">Lesson 02</span>
                        </div>
                        <div class="flex items-center gap-1.5 bg-secondary/5 px-2.5 py-1 rounded-full border border-secondary/10">
                            <span class="material-symbols-outlined text-tertiary !text-sm animate-pulse" style="font-variation-settings: 'FILL' 1;">bolt</span>
                            <span class="text-[9px] font-black text-secondary uppercase tracking-widest">In Progress</span>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-2xl font-black text-on-surface mb-1 italic tracking-tight">Countable & Uncountable</h3>
                        <p class="text-on-surface/50 text-[10px] font-black uppercase tracking-widest">Continue where you left off</p>
                    </div>

                    <div class="space-y-5">
                        <div class="flex items-center gap-3">
                            <div class="h-2.5 w-full bg-surface rounded-full overflow-hidden border border-primary/5 shadow-inner">
                                <div class="h-full bg-tertiary rounded-full shadow-[0_0_15px_rgba(255,179,0,0.5)]" style="width: 65%"></div>
                            </div>
                            <span class="text-[10px] font-black text-on-surface uppercase tracking-tighter whitespace-nowrap">65%</span>
                        </div>
                        <div class="w-full bg-primary text-white py-4 rounded-full font-black text-center text-sm shadow-xl shadow-primary/20 transition-all group-hover:scale-[1.02]">
                            Resume Learning
                        </div>
                    </div>
                </div>
            </a>

            <div class="relative bg-surface-variant/20 rounded-4xl border border-primary/5 grayscale opacity-60 overflow-hidden">
                <div class="p-8 flex flex-col gap-6">
                    <div class="flex justify-between items-start">
                        <div class="bg-on-surface/5 px-4 py-1.5 rounded-full">
                            <span class="text-[10px] uppercase font-black tracking-widest text-on-surface/40 text-center flex">Lesson 03</span>
                        </div>
                        <span class="material-symbols-outlined text-on-surface/40 !text-xl flex items-center justify-center">lock</span>
                    </div>
                    <div>
                        <h3 class="text-2xl font-black text-on-surface/40 mb-1 italic tracking-tight">Proper & Common Nouns</h3>
                        <p class="text-on-surface/40 text-[10px] font-black uppercase tracking-widest">Unlock after Lesson 02</p>
                    </div>
                    <div class="h-2 w-full bg-on-surface/5 rounded-full overflow-hidden">
                        <div class="h-full bg-on-surface/10 w-0"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-16 flex justify-center">
            <div class="p-10 bg-white/40 backdrop-blur-xl rounded-4xl text-center max-w-xs border border-white shadow-sm relative overflow-hidden group hover:shadow-md transition-shadow">
                <div class="absolute inset-0 bg-gradient-to-br from-tertiary/5 to-transparent"></div>
                <div class="w-20 h-20 mx-auto mb-4 bg-white rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-500">
                     <span class="material-symbols-outlined !text-4xl text-tertiary" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
                </div>
                <h4 class="font-black text-on-surface text-sm italic tracking-tight">Keep reaching for the stars!</h4>
                <p class="text-on-surface/50 text-[10px] font-black uppercase tracking-widest mt-2 leading-relaxed">
                    You're doing great,<br/>star student.
                </p>
            </div>
        </div>
    </main>
</MainLayout>