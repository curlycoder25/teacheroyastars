---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Nouns - Lessons">
    <main class="pt-24 pb-32 px-6 max-w-2xl mx-auto relative overflow-hidden">
        
        <section class="mb-10 text-center">
            <h2 class="text-3xl font-black text-on-surface mb-2 tracking-tight italic">Topic 01: Nouns</h2>
            <p class="text-on-surface/60 text-sm font-medium leading-relaxed">Explore the different types of nouns in our grammar galaxy.</p>
        </section>

        <div class="space-y-6">
            
            <div class="relative group overflow-hidden bg-secondary rounded-4xl p-8 shadow-xl shadow-secondary/20 transition-all active:scale-[0.98]">
                <div class="absolute -top-4 -right-4 text-white opacity-20 transform rotate-12 pointer-events-none">
                    <span class="material-symbols-outlined !text-6xl" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                
                <div class="relative z-10 flex flex-col gap-6">
                    <div class="flex justify-between items-start">
                        <div class="bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full border border-white/10">
                            <span class="text-[10px] uppercase font-black tracking-widest text-white">Lesson 01</span>
                        </div>
                        <span class="material-symbols-outlined text-white !text-2xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    </div>
                    
                    <div>
                        <h3 class="text-xl font-black text-white mb-1 italic">Compound Nouns</h3>
                        <p class="text-white/70 text-xs font-medium uppercase tracking-wider">Completed on Oct 12</p>
                    </div>

                    <div class="flex items-center gap-3">
                        <div class="h-2 w-full bg-white/20 rounded-full overflow-hidden">
                            <div class="h-full bg-tertiary w-full shadow-[0_0_10px_rgba(255,179,0,0.5)]"></div>
                        </div>
                        <span class="text-[10px] font-black text-white">100%</span>
                    </div>
                </div>
            </div>

            <div class="relative group bg-white rounded-4xl p-8 shadow-sm border border-primary/5 transition-all active:scale-[0.98]">
                <div class="absolute -top-4 -right-4 text-tertiary opacity-10 transform rotate-12 pointer-events-none">
                    <span class="material-symbols-outlined !text-6xl" style="font-variation-settings: 'FILL' 0;">star</span>
                </div>
                
                <div class="relative z-10 flex flex-col gap-6">
                    <div class="flex justify-between items-start">
                        <div class="bg-surface px-3 py-1 rounded-full border border-primary/5">
                            <span class="text-[10px] uppercase font-black tracking-widest text-primary">Lesson 02</span>
                        </div>
                        <div class="flex items-center gap-1.5 bg-secondary/5 px-2 py-1 rounded-full">
                            <span class="material-symbols-outlined text-tertiary !text-sm animate-pulse" style="font-variation-settings: 'FILL' 1;">bolt</span>
                            <span class="text-[9px] font-black text-secondary uppercase tracking-widest">In Progress</span>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-xl font-black text-on-surface mb-1 italic">Countable & Uncountable</h3>
                        <p class="text-on-surface/50 text-xs font-medium uppercase tracking-wider">Continue where you left off</p>
                    </div>

                    <div class="space-y-4">
                        <div class="flex items-center gap-3">
                            <div class="h-2.5 w-full bg-surface rounded-full overflow-hidden border border-primary/5 shadow-inner">
                                <div class="h-full bg-tertiary rounded-full shadow-[0_0_12px_rgba(255,179,0,0.4)]" style="width: 65%"></div>
                            </div>
                            <span class="text-[10px] font-black text-on-surface">65%</span>
                        </div>
                        <button class="w-full bg-primary text-white py-4 rounded-full font-black text-sm shadow-lg shadow-primary/20 active:scale-95 transition-all">
                            Resume Learning
                        </button>
                    </div>
                </div>
            </div>

            <div class="relative bg-surface-variant/20 rounded-4xl border border-primary/5 grayscale opacity-60">
                <div class="p-8 flex flex-col gap-6">
                    <div class="flex justify-between items-start">
                        <div class="bg-on-surface/5 px-3 py-1 rounded-full">
                            <span class="text-[10px] uppercase font-black tracking-widest text-on-surface/40">Lesson 03</span>
                        </div>
                        <span class="material-symbols-outlined text-on-surface/40 !text-xl">lock</span>
                    </div>
                    <div>
                        <h3 class="text-xl font-black text-on-surface/40 mb-1 italic">Proper & Common Nouns</h3>
                        <p class="text-on-surface/40 text-[10px] font-black uppercase tracking-widest">Unlock after Lesson 02</p>
                    </div>
                    <div class="h-2 w-full bg-on-surface/5 rounded-full overflow-hidden">
                        <div class="h-full bg-on-surface/10 w-0"></div>
                    </div>
                </div>
            </div>

            <div class="relative bg-surface-variant/20 rounded-4xl border border-primary/5 grayscale opacity-60">
                <div class="p-8 flex flex-col gap-6">
                    <div class="flex justify-between items-start">
                        <div class="bg-on-surface/5 px-3 py-1 rounded-full">
                            <span class="text-[10px] uppercase font-black tracking-widest text-on-surface/40">Lesson 04</span>
                        </div>
                        <span class="material-symbols-outlined text-on-surface/40 !text-xl">lock</span>
                    </div>
                    <div>
                        <h3 class="text-xl font-black text-on-surface/40 mb-1 italic">Abstract & Concrete</h3>
                        <p class="text-on-surface/40 text-[10px] font-black uppercase tracking-widest">Locked in the galaxy</p>
                    </div>
                    <div class="h-2 w-full bg-on-surface/5 rounded-full overflow-hidden">
                        <div class="h-full bg-on-surface/10 w-0"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-16 flex justify-center">
            <div class="p-8 bg-white/40 backdrop-blur-xl rounded-4xl text-center max-w-xs border border-white shadow-sm relative overflow-hidden group">
                <div class="absolute inset-0 bg-gradient-to-br from-tertiary/5 to-transparent"></div>
                <img class="w-20 h-20 mx-auto mb-4 drop-shadow-lg group-hover:scale-110 transition-transform duration-500" 
                     src="/api/placeholder/80/80" 
                     alt="Motivation Rocket"/>
                <h4 class="font-black text-on-surface text-sm italic">Keep reaching for the stars!</h4>
                <p class="text-on-surface/60 text-[10px] font-black uppercase tracking-widest mt-2">You're doing great, star student.</p>
            </div>
        </div>
    </main>
</MainLayout>