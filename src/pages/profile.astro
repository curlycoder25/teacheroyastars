---
import MainLayout from '../layouts/MainLayout.astro';

// İstifadəçi məlumatları
const user = {
    name: "John",
    surname: "Doe",
    email: "john.doe@starstudent.edu",
    phone: "+1 (555) 000-1234",
    status: "Gold Star Student",
    initials: "JD"
};

// Rəng mövzuları (Themes)
const themes = [
    { name: "Default", color: "bg-[#155f98]", active: true },
    { name: "Green", color: "bg-[#4CAF50]" },
    { name: "Yellow", color: "bg-[#FFEB3B]" },
    { name: "Pink", color: "bg-[#ffc1cc]" },
    { name: "Purple", color: "bg-[#9C27B0]" },
    { name: "Orange", color: "bg-[#FF9800]" }
];
---

<MainLayout title="Profile" hideHeader={true}>
    <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md flex justify-between items-center px-6 py-4 border-b border-[#d1e4ff]">
        <div class="flex items-center gap-3">
            <h1 class="text-xl font-black tracking-tight">
                <span class="text-[#155f98]">Teacher </span>
                <span class="text-[#b5161e]">Roya</span>
                <span class="text-[#155f98]">'s Stars✨</span>
            </h1>
        </div>
        <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-[#d1e4ff] shadow-sm bg-[#83bdfd] flex items-center justify-center text-white font-bold text-xs">
            {user.initials}
        </div>
    </nav>

    <main class="pt-24 pb-32 px-6 max-w-2xl mx-auto space-y-8">
        
        <section class="relative bg-white rounded-2xl p-8 shadow-sm flex flex-col items-center overflow-hidden border border-[#d1e4ff]/30">
            <div class="absolute -top-4 -right-4 text-[#feb300] opacity-40 transform rotate-12">
                <span class="material-symbols-outlined text-6xl" style="font-variation-settings: 'FILL' 1;">star</span>
            </div>
            
            <div class="relative">
                <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-[#d1e4ff] p-1 shadow-lg bg-white">
                    <div class="w-full h-full bg-[#83bdfd] rounded-full flex items-center justify-center text-white text-4xl font-black">
                        {user.initials}
                    </div>
                </div>
                <button class="absolute bottom-0 right-0 bg-[#155f98] text-white p-2.5 rounded-full shadow-lg active:scale-95 transition-transform">
                    <span class="material-symbols-outlined text-lg">edit</span>
                </button>
            </div>
            
            <div class="mt-6 text-center">
                <h2 class="text-2xl font-extrabold text-[#213041]">{user.name} {user.surname}</h2>
                <p class="text-[#4e5d6f] font-bold text-sm flex items-center justify-center gap-1.5 mt-1">
                    <span class="material-symbols-outlined text-[#feb300] text-lg" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
                    {user.status}
                </p>
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex items-center gap-2 px-1">
                <span class="material-symbols-outlined text-[#155f98]">person_outline</span>
                <h3 class="text-lg font-bold text-[#213041]">Account Details</h3>
            </div>
            
            <div class="bg-white rounded-2xl p-6 space-y-5 border border-[#d1e4ff]/30 shadow-sm">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-[#9faec4] ml-1">Name</label>
                        <div class="bg-[#f3f6ff] rounded-xl px-4 py-3.5 text-[#213041] font-bold text-sm">
                            {user.name}
                        </div>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-[#9faec4] ml-1">Surname</label>
                        <div class="bg-[#f3f6ff] rounded-xl px-4 py-3.5 text-[#213041] font-bold text-sm">
                            {user.surname}
                        </div>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-black uppercase tracking-widest text-[#9faec4] ml-1">Email</label>
                    <div class="bg-[#f3f6ff] rounded-xl px-4 py-3.5 flex items-center justify-between text-[#213041] font-bold text-sm">
                        <span>{user.email}</span>
                        <span class="material-symbols-outlined text-[#4CAF50] text-base">verified</span>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-black uppercase tracking-widest text-[#9faec4] ml-1">Phone number</label>
                    <div class="bg-[#f3f6ff] rounded-xl px-4 py-3.5 text-[#213041] font-bold text-sm">
                        {user.phone}
                    </div>
                </div>
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex items-center gap-2 px-1">
                <span class="material-symbols-outlined text-[#155f98]">palette</span>
                <h3 class="text-lg font-bold text-[#213041]">Interface Theme</h3>
            </div>
            
            <div class="bg-white rounded-2xl p-6 border border-[#d1e4ff]/30 shadow-sm">
                <div class="grid grid-cols-3 gap-3">
                    {themes.map((theme) => (
                        <button class={`flex flex-col items-center gap-3 p-4 rounded-xl transition-all active:scale-95 ${theme.active ? 'bg-[#155f98] text-white shadow-lg scale-105' : 'bg-[#f3f6ff] text-[#4e5d6f]'}`}>
                            <div class={`w-10 h-10 rounded-full ${theme.color} shadow-inner flex items-center justify-center border-2 border-white`}>
                                {theme.active && <span class="material-symbols-outlined text-white text-base">check</span>}
                            </div>
                            <span class="text-[10px] font-black uppercase tracking-tight">{theme.name}</span>
                        </button>
                    ))}
                </div>
            </div>
        </section>

        <section class="pt-4 pb-10">
            <button class="w-full bg-white border-2 border-[#d1e4ff] text-[#b5161e] py-4 rounded-xl font-black flex items-center justify-center gap-2 active:bg-red-50 transition-all shadow-sm">
                <span class="material-symbols-outlined">logout</span>
                Sign Out
            </button>
        </section>
    </main>
</MainLayout>

<style>
    /* İkon mərkəzləmə tənzimləməsi */
    .material-symbols-outlined {
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>