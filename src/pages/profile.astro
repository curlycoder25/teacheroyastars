---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/profile.css';

// User Data
const user = {
    name: "John",
    surname: "Doe",
    email: "john.doe@starstudent.edu",
    phone: "+1 (555) 000-1234",
    status: "Gold Star Student",
    initials: "JD"
};

// Color Themes
const themes = [
    { name: "Default", color: "bg-[#155f98]", active: true },
    { name: "Green", color: "bg-emerald-500" },
    { name: "Yellow", color: "bg-[#feb300]" },
    { name: "Pink", color: "bg-pink-400" },
    { name: "Purple", color: "bg-purple-600" },
    { name: "Red", color: "bg-[#af101a]" }
];
---

<MainLayout title="My Profile" isUserLoggedIn={true}>
        
        <section class="profile-card">
            <div class="profile-star-decor">
                <span class="material-symbols-outlined !text-8xl">star</span>
            </div>
            
            <div class="relative">
                <div class="avatar-container">
                    <div class="avatar-placeholder">
                        {user.initials}
                    </div>
                </div>
                <button class="avatar-upload-btn">
                    <span class="material-symbols-outlined !text-lg">photo_camera</span>
                </button>
            </div>
            
            <div class="text-center">
                <h2 class="profile-name">{user.name} {user.surname}</h2>
                <div class="inline-flex items-center gap-2 mt-3 bg-[#feb300]/10 px-4 py-1.5 rounded-full border border-yellow-200/50">
                    <span class="material-symbols-outlined text-[#feb300] !text-lg">workspace_premium</span>
                    <span class="text-[#213041] font-black text-[10px] uppercase tracking-widest">{user.status}</span>
                </div>
            </div>
        </section>

        <section class="section-wrapper">
            <div class="section-label">
                <span class="material-symbols-outlined !text-xl text-[#155f98]">person</span>
                <h3 class="section-label-text">Account Details</h3>
            </div>
            
            <form class="profile-form">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="input-group">
                        <label class="field-label">First Name</label>
                        <input type="text" value={user.name} class="profile-input" />
                    </div>
                    <div class="input-group">
                        <label class="field-label">Last Name</label>
                        <input type="text" value={user.surname} class="profile-input" />
                    </div>
                </div>

                <div class="input-group">
                    <label class="field-label">Email Address</label>
                    <div class="relative flex items-center">
                        <input type="email" value={user.email} class="profile-input opacity-70 cursor-not-allowed" readonly />
                        <span class="material-symbols-outlined text-emerald-500 absolute right-4">verified</span>
                    </div>
                </div>

                <div class="input-group">
                    <label class="field-label">Mobile Number</label>
                    <input type="tel" value={user.phone} class="profile-input" />
                </div>

                <div class="pt-4">
                    <button type="submit" class="btn-save">
                        <span class="material-symbols-outlined !text-xl">save</span>
                        Save Galaxy Changes
                    </button>
                </div>
            </form>
        </section>

        <section class="section-wrapper">
            <div class="section-label">
                <span class="material-symbols-outlined !text-xl text-[#155f98]">palette</span>
                <h3 class="section-label-text">Interface Theme</h3>
            </div>
            
            <div class="profile-form">
                <div class="theme-grid">
                    {themes.map((theme) => (
                        <button class={`theme-btn ${theme.active ? 'bg-blue-50 border-blue-400 shadow-sm' : 'bg-transparent border-transparent'}`}>
                            <div class={`w-10 h-10 rounded-full ${theme.color} border-4 border-white shadow-inner flex items-center justify-center`}>
                                {theme.active && <span class="material-symbols-outlined text-white !text-sm">check</span>}
                            </div>
                            <span class="text-[9px] font-black uppercase text-slate-500">{theme.name}</span>
                        </button>
                    ))}
                </div>
            </div>
        </section>

        <section class="max-w-[1000px] mx-auto pb-20">
            <a href="/login" class="btn-logout">
                <span class="material-symbols-outlined !text-xl">logout</span>
                Secure Sign Out
            </a>
        </section>
</MainLayout>