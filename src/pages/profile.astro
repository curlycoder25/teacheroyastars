---
import MainLayout from '../layouts/MainLayout.astro';

// İstifadəçi məlumatları (Gələcəkdə bunları verilənlər bazasından çəkə bilərsən)
const user = {
    name: "John",
    surname: "Doe",
    email: "john.doe@starstudent.edu",
    phone: "+1 (555) 000-1234",
    status: "Gold Star Student",
    initials: "JD"
};

// Rəng mövzuları
const themes = [
    { name: "Default", color: "bg-primary", active: true },
    { name: "Green", color: "bg-emerald-500" },
    { name: "Yellow", color: "bg-tertiary" },
    { name: "Pink", color: "bg-pink-300" },
    { name: "Purple", color: "bg-purple-600" },
    { name: "Orange", color: "bg-orange-500" }
];
---

<MainLayout title="Profile">
    
    <main class="pt-24 pb-32 px-6 max-w-2xl mx-auto space-y-8">
        
        <section class="relative bg-white rounded-4xl p-8 shadow-sm flex flex-col items-center overflow-hidden border border-primary/5">
            <div class="absolute -top-4 -right-4 text-tertiary opacity-40 transform rotate-12">
                <span class="material-symbols-outlined !text-6xl" style="font-variation-settings: 'FILL' 1;">star</span>
            </div>
            
            <div class="relative">
                <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-surface p-1 shadow-lg bg-white">
                    <div class="w-full h-full bg-accent rounded-full flex items-center justify-center text-white text-4xl font-black italic">
                        {user.initials}
                    </div>
                </div>
                <button class="absolute bottom-0 right-0 bg-primary text-white p-2.5 rounded-full shadow-lg active:scale-95 transition-transform border-4 border-white">
                    <span class="material-symbols-outlined text-lg">edit</span>
                </button>
            </div>
            
            <div class="mt-6 text-center">
                <h2 class="text-2xl font-black text-on-surface tracking-tight">{user.name} {user.surname}</h2>
                <p class="text-on-surface-variant font-bold text-xs flex items-center justify-center gap-1.5 mt-1 uppercase tracking-widest">
                    <span class="material-symbols-outlined text-tertiary text-lg" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
                    {user.status}
                </p>
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex items-center gap-2 px-1">
                <span class="material-symbols-outlined text-primary">person_outline</span>
                <h3 class="text-lg font-black text-on-surface">Account Details</h3>
            </div>
            
            <div class="bg-white rounded-4xl p-6 space-y-5 border border-primary/5 shadow-sm">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-on-surface/40 ml-1">Name</label>
                        <div class="bg-surface rounded-2xl px-4 py-3.5 text-on-surface font-bold text-sm">
                            {user.name}
                        </div>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-on-surface/40 ml-1">Surname</label>
                        <div class="bg-surface rounded-2xl px-4 py-3.5 text-on-surface font-bold text-sm">
                            {user.surname}
                        </div>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-black uppercase tracking-widest text-on-surface/40 ml-1">Email</label>
                    <div class="bg-surface rounded-2xl px-4 py-3.5 flex items-center justify-between text-on-surface font-bold text-sm">
                        <span>{user.email}</span>
                        <span class="material-symbols-outlined text-emerald-500 text-base">verified</span>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-black uppercase tracking-widest text-on-surface/40 ml-1">Phone number</label>
                    <div class="bg-surface rounded-2xl px-4 py-3.5 text-on-surface font-bold text-sm">
                        {user.phone}
                    </div>
                </div>
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex items-center gap-2 px-1">
                <span class="material-symbols-outlined text-primary">palette</span>
                <h3 class="text-lg font-black text-on-surface">Interface Theme</h3>
            </div>
            
            <div class="bg-white rounded-4xl p-6 border border-primary/5 shadow-sm">
                <div class="grid grid-cols-3 gap-3">
                    {themes.map((theme) => (
                        <button class={`flex flex-col items-center gap-3 p-4 rounded-3xl transition-all active:scale-95 ${theme.active ? 'bg-primary text-white shadow-lg' : 'bg-surface text-on-surface-variant'}`}>
                            <div class={`w-10 h-10 rounded-full ${theme.color} shadow-inner flex items-center justify-center border-2 border-white`}>
                                {theme.active && <span class="material-symbols-outlined text-white text-base">check</span>}
                            </div>
                            <span class="text-[10px] font-black uppercase tracking-tight">{theme.name}</span>
                        </button>
                    ))}
                </div>
            </div>
        </section>

        <section class="pt-4 pb-10">
            <button class="w-full bg-white border-2 border-primary/10 text-secondary py-4 rounded-full font-black flex items-center justify-center gap-2 active:bg-secondary/5 transition-all shadow-sm">
                <span class="material-symbols-outlined">logout</span>
                Sign Out
            </button>
        </section>
    </main>
</MainLayout>