---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/profile.css';

// User Data
const user = {
    name: "John",
    surname: "Doe",
    email: "john.doe@starstudent.edu",
    phone: "+1 (555) 000-1234",
    status: "Gold Star Student",
    initials: "JD"
};

// Color Themes - data-theme dəyərləri CSS-dəki [data-theme="..."] ilə eyni olmalıdır
const themes = [
    { name: "Default", color: "bg-[#155f98]", value: "default" },
    { name: "Green", color: "bg-emerald-500", value: "green" },
    { name: "Yellow", color: "bg-[#feb300]", value: "yellow" },
    { name: "Pink", color: "bg-pink-400", value: "pink" },
    { name: "Purple", color: "bg-purple-600", value: "purple" },
    { name: "Red", color: "bg-[#af101a]", value: "red" }
];
---

<MainLayout title="My Profile" isUserLoggedIn={true}>
        
        <section class="profile-card">
            <div class="profile-star-decor">
                <span class="material-symbols-outlined !text-8xl">star</span>
            </div>
            
            <div class="relative">
                <div class="avatar-container">
                    <div class="avatar-placeholder">
                        {user.initials}
                    </div>
                </div>
                <button class="avatar-upload-btn">
                    <span class="material-symbols-outlined !text-lg">photo_camera</span>
                </button>
            </div>
            
            <div class="text-center">
                <h2 class="profile-name">{user.name} {user.surname}</h2>
                <div class="inline-flex items-center gap-2 mt-3 bg-tertiary/10 px-4 py-1.5 rounded-full border border-tertiary/20">
                    <span class="material-symbols-outlined text-tertiary !text-lg">workspace_premium</span>
                    <span class="text-on-surface font-black text-[10px] uppercase tracking-widest">{user.status}</span>
                </div>
            </div>
        </section>

        <section class="section-wrapper">
            <div class="section-label">
                <span class="material-symbols-outlined !text-xl text-primary">person</span>
                <h3 class="section-label-text">Account Details</h3>
            </div>
            
            <form class="profile-form" id="profileForm">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="input-group">
                        <label class="field-label">First Name</label>
                        <input type="text" value={user.name} class="profile-input" />
                    </div>
                    <div class="input-group">
                        <label class="field-label">Last Name</label>
                        <input type="text" value={user.surname} class="profile-input" />
                    </div>
                </div>

                <div class="input-group">
                    <label class="field-label">Email Address</label>
                    <div class="relative flex items-center">
                        <input type="email" value={user.email} class="profile-input opacity-70 cursor-not-allowed" readonly />
                        <span class="material-symbols-outlined text-emerald-500 absolute right-4">verified</span>
                    </div>
                </div>

                <div class="input-group">
                    <label class="field-label">Mobile Number</label>
                    <input type="tel" value={user.phone} class="profile-input" />
                </div>

                <div class="pt-4">
                    <button type="submit" class="btn-save">
                        <span class="material-symbols-outlined !text-xl">save</span>
                        Save Galaxy Changes
                    </button>
                </div>
            </form>
        </section>

        <section class="section-wrapper">
            <div class="section-label">
                <span class="material-symbols-outlined !text-xl text-primary">palette</span>
                <h3 class="section-label-text">Interface Theme</h3>
            </div>
            
            <div class="profile-form">
                <div class="theme-grid" id="themePicker">
                    {themes.map((theme) => (
                        <button 
                            type="button" 
                            data-theme-value={theme.value}
                            class="theme-btn border-transparent"
                        >
                            <div class={`w-10 h-10 rounded-full ${theme.color} border-4 border-white shadow-inner flex items-center justify-center pointer-events-none`}>
                                <span class="check-icon material-symbols-outlined text-white !text-sm hidden">check</span>
                            </div>
                            <span class="text-[9px] font-black uppercase text-slate-500 pointer-events-none">{theme.name}</span>
                        </button>
                    ))}
                </div>
            </div>
        </section>

        <section class="max-w-[1000px] mx-auto pb-20">
            <a href="/login" class="btn-logout">
                <span class="material-symbols-outlined !text-xl">logout</span>
                Secure Sign Out
            </a>
        </section>
</MainLayout>

<script>
    const themeButtons = document.querySelectorAll('[data-theme-value]');
    const profileForm = document.getElementById('profileForm');
    
    // Cari seçimi localStorage-dan götür və ya default et
    let currentTheme = localStorage.getItem('theme') || 'default';

    // UI-ni cari seçilmiş mövzuya görə yenilə
    function updateThemeUI(selected: string) {
        themeButtons.forEach(btn => {
            const val = btn.getAttribute('data-theme-value');
            const check = btn.querySelector('.check-icon');
            
            if (val === selected) {
                btn.classList.add('theme-active');
                check?.classList.remove('hidden');
            } else {
                btn.classList.remove('theme-active');
                check?.classList.add('hidden');
            }
        });
    }

    // Klik hadisəsi
    themeButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            currentTheme = btn.getAttribute('data-theme-value') || 'default';
            updateThemeUI(currentTheme);
        });
    });

    // Save düyməsinə basanda tətbiq et
    profileForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        localStorage.setItem('theme', currentTheme);
        document.documentElement.setAttribute('data-theme', currentTheme);
        
        // Kiçik bildiriş (Opsional)
        alert('Galaxy Theme Updated!');
    });

    // İlkin yüklənmədə aktiv olanı göstər
    updateThemeUI(currentTheme);
</script>