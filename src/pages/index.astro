---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Ana Səhifə">
    <main class="pt-24 pb-32 px-6 flex flex-col items-center justify-center min-h-screen relative overflow-hidden">
        
        <div class="absolute inset-0 star-pattern pointer-events-none"></div>

        <div class="relative w-full max-w-md mx-auto z-10">
            
            <div class="relative mb-12 flex justify-center items-center">
                
                <div class="absolute -top-10 -right-4 text-[#feb300] animate-pulse">
                    <span class="material-symbols-outlined text-6xl" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                
                <div class="absolute -bottom-8 -left-6 text-[#83bdfd] opacity-40 transform -rotate-12">
                    <span class="material-symbols-outlined text-5xl" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
                </div>

                <div class="bg-white rounded-full p-6 shadow-2xl shadow-[#155f98]/10 border-4 border-[#d1e4ff] relative overflow-hidden group">
                    <div class="w-40 h-40 rounded-full bg-[#83bdfd] flex items-center justify-center text-white text-5xl font-bold overflow-hidden transition-transform duration-700 group-hover:scale-110">
                        TR
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-t from-[#b5161e]/10 to-transparent pointer-events-none"></div>
                </div>
            </div>

            <div class="text-center space-y-6">
                <h2 class="text-4xl font-extrabold text-[#213041] tracking-tight leading-tight px-2">
                    Ready to start your <span class="text-[#b5161e]">English</span> adventure?
                </h2>
                <p class="text-[#4e5d6f] text-lg font-medium max-w-[280px] mx-auto opacity-80">
                    Unlock the galaxy of knowledge with Teacher Roya.
                </p>
                
                <div class="flex flex-col gap-4 mt-8">
                    <button class="bg-[#b5161e] text-white py-4 px-8 rounded-full font-bold text-lg shadow-lg shadow-[#b5161e]/20 active:scale-95 transition-all duration-200">
                        Sign Up
                    </button>
                    <button class="bg-[#d1e4ff]/50 text-[#213041] py-4 px-8 rounded-full font-bold text-lg border border-[#9faec4]/15 active:scale-95 transition-all backdrop-blur-sm">
                        Log In
                    </button>
                </div>
            </div>

            <div class="mt-16 grid grid-cols-2 gap-4">
                <div class="bg-[#e9f1ff] p-4 rounded-2xl flex flex-col items-center gap-2 border border-[#d1e4ff]/30">
                    <span class="material-symbols-outlined text-[#feb300]" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-[#69788c]">500+ Stars Earned</span>
                </div>
                <div class="bg-[#e9f1ff] p-4 rounded-2xl flex flex-col items-center gap-2 border border-[#d1e4ff]/30">
                    <span class="material-symbols-outlined text-[#b5161e]" style="font-variation-settings: 'FILL' 1;">groups</span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-[#69788c]">Active Learners</span>
                </div>
            </div>

        </div>
    </main>
</MainLayout>