---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Welcome" isIndex={true} hideNavbar={true}>
    <section class="relative flex flex-col items-center justify-center py-12">
        
        <div class="absolute inset-0 opacity-10 pointer-events-none bg-gradient-to-b from-[#155f98] to-transparent"></div>

        <div class="relative w-full max-w-md mx-auto z-10">
            
            <div class="relative mb-12 flex justify-center items-center">
                <div class="absolute -top-12 -right-2 text-[#feb300] animate-pulse">
                    <span class="material-symbols-outlined !text-6xl" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div class="absolute -bottom-10 -left-8 text-[#83bdfd] opacity-40 transform -rotate-12">
                    <span class="material-symbols-outlined !text-5xl" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
                </div>

                <div class="bg-white rounded-full p-4 shadow-2xl shadow-[#155f98]/10 border-4 border-[#83bdfd]/20 relative overflow-hidden group">
                    <div class="w-36 h-36 rounded-full bg-[#83bdfd] flex items-center justify-center text-white text-5xl font-black transition-transform duration-700 group-hover:scale-110">
                        TR
                    </div>
                </div>
            </div>

            <div class="text-center space-y-6">
                <h2 class="text-4xl font-black text-[#213041] tracking-tight leading-tight px-2 uppercase italic">
                    Ready to start your <span class="text-[#b5161e]">English</span> adventure?
                </h2>
                <p class="text-[#213041]/70 text-lg font-medium max-w-xs mx-auto italic leading-relaxed">
                    Unlock the galaxy of knowledge with Teacher Roya.
                </p>
                
                <div class="flex flex-col gap-4 mt-8">
                    <a href="/signup" class="bg-[#b5161e] text-white py-5 px-8 rounded-full font-black text-lg shadow-xl shadow-[#b5161e]/20 active:scale-95 transition-all uppercase tracking-widest text-center no-underline">
                        Sign Up
                    </a>
                    <a href="/login" class="bg-white text-[#213041] py-5 px-8 rounded-full font-black text-lg border-2 border-[#d1e4ff] active:scale-95 transition-all backdrop-blur-md uppercase tracking-widest text-center no-underline">
                        Log In
                    </a>
                </div>
            </div>

            <div class="mt-16 grid grid-cols-2 gap-4">
                <div class="bg-white/50 backdrop-blur-sm p-6 rounded-[32px] flex flex-col items-center gap-3 border border-[#d1e4ff] shadow-sm">
                    <span class="material-symbols-outlined text-[#feb300] !text-3xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                    <span class="text-[10px] font-black uppercase tracking-widest text-[#213041]/50 text-center leading-tight">
                        500+ Stars Earned
                    </span>
                </div>
                
                <div class="bg-white/50 backdrop-blur-sm p-6 rounded-[32px] flex flex-col items-center gap-3 border border-[#d1e4ff] shadow-sm">
                    <span class="material-symbols-outlined text-[#b5161e] !text-3xl" style="font-variation-settings: 'FILL' 1;">groups</span>
                    <span class="text-[10px] font-black uppercase tracking-widest text-[#213041]/50 text-center leading-tight">
                        Active Learners
                    </span>
                </div>
            </div>
        </div>
    </section>
</MainLayout>