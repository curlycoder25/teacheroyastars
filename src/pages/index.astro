---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Ana Səhifə" isIndex={true}>
    <section class="relative flex flex-col items-center justify-center px-6 py-12 overflow-hidden">
        
        <div class="absolute inset-0 opacity-10 pointer-events-none bg-[radial-gradient(circle_at_center,theme(colors.primary)_0%,transparent_70%)]"></div>

        <div class="relative w-full max-w-md mx-auto z-10">
            
            <div class="relative mb-12 flex justify-center items-center">
                <div class="absolute -top-12 -right-2 text-tertiary animate-pulse">
                    <span class="material-symbols-outlined !text-6xl" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div class="absolute -bottom-10 -left-8 text-accent opacity-40 transform -rotate-12">
                    <span class="material-symbols-outlined !text-5xl" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
                </div>

                <div class="bg-white rounded-full p-4 shadow-2xl shadow-primary/10 border-4 border-accent/20 relative overflow-hidden group">
                    <div class="w-36 h-36 rounded-full bg-accent flex items-center justify-center text-white text-5xl font-black transition-transform duration-700 group-hover:scale-110">
                        TR
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-t from-secondary/10 to-transparent pointer-events-none"></div>
                </div>
            </div>

            <div class="text-center space-y-6">
                <h2 class="text-4xl font-black text-on-surface tracking-tight leading-tight px-2">
                    Ready to start your <span class="text-secondary italic">English</span> adventure?
                </h2>
                <p class="text-on-surface/70 text-lg font-medium max-w-xs mx-auto">
                    Unlock the galaxy of knowledge with Teacher Roya.
                </p>
                
                <div class="flex flex-col gap-4 mt-8">
                    <button class="bg-secondary text-white py-4 px-8 rounded-full font-bold text-lg shadow-lg shadow-secondary/25 active:scale-95 transition-all">
                        Sign Up
                    </button>
                    <button class="bg-white text-on-surface py-4 px-8 rounded-full font-bold text-lg border border-accent/20 active:scale-95 transition-all backdrop-blur-md">
                        Log In
                    </button>
                </div>
            </div>

            <div class="mt-16 grid grid-cols-2 gap-4">
                <div class="bg-accent/10 p-5 rounded-3xl flex flex-col items-center gap-3 border border-accent/5">
                    <span class="material-symbols-outlined text-tertiary !text-3xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                    <span class="text-[10px] font-black uppercase tracking-widest text-on-surface/50 text-center leading-tight">
                        500+ Stars Earned
                    </span>
                </div>
                
                <div class="bg-accent/10 p-5 rounded-3xl flex flex-col items-center gap-3 border border-accent/5">
                    <span class="material-symbols-outlined text-secondary !text-3xl" style="font-variation-settings: 'FILL' 1;">groups</span>
                    <span class="text-[10px] font-black uppercase tracking-widest text-on-surface/50 text-center leading-tight">
                        Active Learners
                    </span>
                </div>
            </div>
        </div>
    </section>
</MainLayout>