---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Grade 9 Exams">
    <main class="pt-24 pb-32 px-6 max-w-5xl mx-auto relative overflow-hidden">
        
        <section class="mb-10 relative overflow-hidden rounded-4xl bg-secondary p-10 text-white shadow-2xl shadow-secondary/20 group">
            <div class="relative z-10 space-y-4">
                <span class="bg-white/20 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-white/10 inline-block">Current Focus</span>
                <h2 class="text-4xl font-black italic tracking-tight">Grade 9 Exams</h2>
                <p class="opacity-80 max-w-md font-medium text-sm leading-relaxed">
                    Master your curriculum with our curated mock exams and past papers. Aim for the stars!
                </p>
            </div>
            
            <div class="absolute -right-10 -top-10 w-64 h-64 bg-tertiary/20 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute right-8 bottom-8 opacity-20 text-8xl material-symbols-outlined pointer-events-none group-hover:rotate-12 transition-transform duration-700" style="font-variation-settings: 'FILL' 1;">auto_awesome</div>
        </section>

        <div class="flex items-center justify-between mb-8 px-2">
            <h3 class="text-xl font-black text-on-surface tracking-tight uppercase italic">Mock Exams</h3>
            <button class="text-primary font-black text-xs uppercase tracking-widest hover:opacity-80 transition-all">View Statistics</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
            
            <div class="group relative rounded-4xl bg-secondary p-8 text-white flex flex-col justify-between min-h-[260px] shadow-xl shadow-secondary/20 active:scale-[0.98] transition-all cursor-pointer">
                <div class="absolute top-0 right-0 p-6 opacity-20 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined !text-6xl" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-6">
                        <span class="bg-white/20 px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border border-white/10">In Progress</span>
                    </div>
                    <h4 class="text-2xl font-black italic tracking-tight">Mock Exam 1</h4>
                    <p class="text-sm opacity-70 font-medium">Full Curriculum Assessment</p>
                </div>
                <div class="space-y-3">
                    <div class="flex justify-between items-end text-[10px] font-black uppercase tracking-widest opacity-80">
                        <span>Readiness</span>
                        <span>65%</span>
                    </div>
                    <div class="h-2 w-full bg-white/20 rounded-full overflow-hidden shadow-inner">
                        <div class="h-full bg-tertiary rounded-full shadow-[0_0_12px_rgba(255,179,0,0.6)]" style="width: 65%"></div>
                    </div>
                </div>
            </div>

            <div class="group relative rounded-4xl bg-white p-8 flex flex-col justify-between min-h-[260px] border border-primary/5 shadow-sm active:scale-[0.98] transition-all cursor-pointer">
                <div>
                    <div class="flex items-center gap-2 mb-6">
                        <span class="bg-surface text-on-surface/40 px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border border-primary/5">Not Started</span>
                    </div>
                    <h4 class="text-2xl font-black text-on-surface italic tracking-tight">Mock Exam 2</h4>
                    <p class="text-sm text-on-surface/50 font-medium leading-relaxed">Mid-Term Specialized Grammar Unit</p>
                </div>
                <button class="w-full bg-primary text-white font-black py-4 rounded-full flex items-center justify-center gap-2 shadow-lg shadow-primary/10 uppercase tracking-widest text-xs group-hover:scale-[1.02] transition-transform">
                    Start Now
                    <span class="material-symbols-outlined !text-lg">play_arrow</span>
                </button>
            </div>

            <div class="group relative rounded-4xl bg-white p-8 flex flex-col justify-between min-h-[260px] border border-primary/5 shadow-sm active:scale-[0.98] transition-all cursor-pointer">
                <div class="absolute top-6 right-8">
                    <span class="material-symbols-outlined text-tertiary !text-3xl" style="font-variation-settings: 'FILL' 1;">verified</span>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-6">
                        <span class="bg-tertiary/10 text-tertiary px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest">Completed</span>
                    </div>
                    <h4 class="text-2xl font-black text-on-surface italic tracking-tight">Mock Exam 3</h4>
                    <p class="text-sm text-on-surface/50 font-medium">General Knowledge Review</p>
                </div>
                <div class="flex items-center justify-between p-4 bg-surface rounded-3xl border border-primary/5">
                    <span class="text-xs font-black text-secondary uppercase tracking-widest">Score: 92%</span>
                    <span class="text-primary font-black text-xs uppercase tracking-widest cursor-pointer hover:underline italic">Review</span>
                </div>
            </div>
        </div>

        <h3 class="text-xl font-black text-on-surface tracking-tight mb-8 px-2 uppercase italic">Past Papers</h3>
        
        <div class="space-y-4 px-1">
            
            <div class="group flex items-center gap-6 bg-white p-6 rounded-4xl border border-primary/5 shadow-sm opacity-60 grayscale active:scale-[0.99] transition-all cursor-not-allowed">
                <div class="w-16 h-16 bg-surface rounded-2xl flex items-center justify-center text-on-surface/20 font-black text-2xl italic shadow-inner">
                    01
                </div>
                <div class="flex-1">
                    <h5 class="font-black text-on-surface italic">Past Paper 2023 - Session A</h5>
                    <p class="text-[11px] font-bold text-on-surface/40 uppercase tracking-widest mt-1">Mathematics & Sciences • 45 Questions</p>
                </div>
                <div class="flex items-center gap-4">
                    <span class="bg-on-surface/5 text-on-surface/40 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-primary/5">LOCKED</span>
                    <span class="material-symbols-outlined text-on-surface/20 !text-2xl">lock</span>
                </div>
            </div>

            <div class="group flex items-center gap-6 bg-white p-6 rounded-4xl border border-primary/5 shadow-sm active:scale-[0.99] transition-all cursor-pointer hover:shadow-md hover:border-primary/10">
                <div class="w-16 h-16 bg-secondary/5 rounded-2xl flex items-center justify-center text-secondary font-black text-2xl italic shadow-inner border border-secondary/5">
                    02
                </div>
                <div class="flex-1">
                    <h5 class="font-black text-on-surface italic">Past Paper 2022 - Finals</h5>
                    <p class="text-[11px] font-bold text-on-surface/40 uppercase tracking-widest mt-1">Full Set • 120 Minutes</p>
                </div>
                <div class="flex items-center gap-4">
                    <span class="bg-tertiary text-on-tertiary-container px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg shadow-tertiary/20">Ready</span>
                    <span class="material-symbols-outlined text-primary !text-2xl group-hover:translate-x-1 transition-transform">chevron_right</span>
                </div>
            </div>

            <div class="group flex items-center gap-6 bg-white p-6 rounded-4xl border border-primary/5 shadow-sm active:scale-[0.99] transition-all cursor-pointer hover:shadow-md">
                <div class="w-16 h-16 bg-tertiary/10 rounded-2xl flex items-center justify-center text-tertiary font-black text-2xl italic shadow-inner border border-tertiary/5">
                    03
                </div>
                <div class="flex-1">
                    <h5 class="font-black text-on-surface italic">Past Paper 2021 - Session B</h5>
                    <p class="text-[11px] font-bold text-on-surface/40 uppercase tracking-widest mt-1">Languages & Social Studies</p>
                </div>
                <div class="flex items-center gap-4">
                    <span class="bg-surface text-on-surface/40 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-primary/5">Completed</span>
                    <span class="material-symbols-outlined text-tertiary !text-2xl" style="font-variation-settings: 'FILL' 1;">grade</span>
                </div>
            </div>

        </div>
    </main>
</MainLayout>