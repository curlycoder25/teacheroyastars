---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Grade 9 Exams">
    <main class="pt-24 pb-32 px-6 max-w-5xl mx-auto relative">
        
        <section class="mb-10 relative overflow-hidden rounded-[48px] bg-secondary p-10 text-white shadow-2xl shadow-secondary/20 group">
            <div class="relative z-10 space-y-4">
                <span class="bg-white/20 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-white/10 inline-block">Current Focus</span>
                <h2 class="text-4xl font-black italic tracking-tight">Grade 9 Exams</h2>
                <p class="opacity-80 max-w-md font-medium text-sm leading-relaxed">
                    Master your curriculum with our curated mock exams and past papers. Aim for the stars!
                </p>
            </div>
            
            <div class="absolute -right-10 -top-10 w-64 h-64 bg-tertiary/20 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute right-10 bottom-10 opacity-30 text-8xl material-symbols-outlined pointer-events-none" style="font-variation-settings: 'FILL' 1;">auto_awesome</div>
        </section>

        <div class="flex items-center justify-between mb-8 px-4">
            <h3 class="text-xl font-black text-on-surface tracking-tight uppercase italic">Mock Exams</h3>
            <button class="text-primary font-black text-xs uppercase tracking-widest hover:opacity-80 transition-all italic">View Statistics</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            
            <div class="group relative rounded-[40px] bg-secondary p-8 text-white flex flex-col justify-between min-h-[280px] shadow-xl shadow-secondary/20 active:scale-[0.98] transition-all cursor-pointer border-4 border-white/5">
                <div class="absolute top-6 right-8 opacity-40 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined !text-6xl" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-6">
                        <span class="bg-white/20 px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest border border-white/10">In Progress</span>
                    </div>
                    <h4 class="text-2xl font-black italic tracking-tight">Mock Exam 1</h4>
                    <p class="text-sm opacity-70 font-medium italic">Full Curriculum Assessment</p>
                </div>
                <div class="space-y-4">
                    <div class="flex justify-between items-end text-[10px] font-black uppercase tracking-widest opacity-80">
                        <span>Progress</span>
                        <span>65%</span>
                    </div>
                    <div class="h-2.5 w-full bg-white/20 rounded-full overflow-hidden shadow-inner">
                        <div class="h-full bg-tertiary rounded-full shadow-[0_0_15px_rgba(255,179,0,0.6)]" style="width: 65%"></div>
                    </div>
                </div>
            </div>

            <div class="group relative rounded-[40px] bg-white p-8 flex flex-col justify-between min-h-[280px] border border-primary/5 shadow-sm active:scale-[0.98] transition-all cursor-pointer">
                <div>
                    <div class="flex items-center gap-2 mb-6">
                        <span class="bg-surface text-on-surface/40 px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest border border-primary/5">Not Started</span>
                    </div>
                    <h4 class="text-2xl font-black text-on-surface italic tracking-tight">Mock Exam 2</h4>
                    <p class="text-sm text-on-surface/50 font-medium leading-relaxed italic">Mid-Term Specialized Unit</p>
                </div>
                <button class="w-full bg-primary text-white font-black py-4 rounded-full flex items-center justify-center gap-2 shadow-lg shadow-primary/10 uppercase tracking-widest text-xs group-hover:bg-primary-dim transition-colors">
                    Start Now
                    <span class="material-symbols-outlined !text-lg">play_arrow</span>
                </button>
            </div>

            <div class="group relative rounded-[40px] bg-white p-8 flex flex-col justify-between min-h-[280px] border border-primary/5 shadow-sm active:scale-[0.98] transition-all cursor-pointer">
                <div class="absolute top-6 right-8">
                    <span class="material-symbols-outlined text-tertiary !text-3xl" style="font-variation-settings: 'FILL' 1;">verified</span>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-6">
                        <span class="bg-tertiary/10 text-tertiary px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest">Completed</span>
                    </div>
                    <h4 class="text-2xl font-black text-on-surface italic tracking-tight">Mock Exam 3</h4>
                    <p class="text-sm text-on-surface/50 font-medium italic">General Knowledge</p>
                </div>
                <div class="flex items-center justify-between p-4 bg-surface rounded-[24px] border border-primary/5">
                    <span class="text-[10px] font-black text-secondary uppercase tracking-widest">Score: 92%</span>
                    <span class="text-primary font-black text-[10px] uppercase tracking-widest cursor-pointer hover:underline italic">Review</span>
                </div>
            </div>
        </div>

        <h3 class="text-xl font-black text-on-surface tracking-tight mb-8 px-4 uppercase italic">Past Papers</h3>
        
        <div class="space-y-4 px-2">
            <div class="group flex items-center gap-6 bg-white p-6 rounded-[32px] border border-primary/5 shadow-sm active:scale-[0.99] transition-all cursor-pointer hover:shadow-md">
                <div class="w-16 h-16 bg-secondary/5 rounded-[24px] flex items-center justify-center text-secondary font-black text-2xl italic shadow-inner border border-secondary/5">
                    02
                </div>
                <div class="flex-1">
                    <h5 class="font-black text-on-surface italic">Past Paper 2022 - Finals</h5>
                    <p class="text-[10px] font-bold text-on-surface/40 uppercase tracking-widest mt-1">Full Set • 120 Minutes</p>
                </div>
                <div class="flex items-center gap-4">
                    <span class="bg-tertiary text-on-tertiary-container px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg shadow-tertiary/20">Ready</span>
                    <span class="material-symbols-outlined text-primary !text-2xl group-hover:translate-x-1 transition-transform">chevron_right</span>
                </div>
            </div>
        </div>
    </main>
</MainLayout>