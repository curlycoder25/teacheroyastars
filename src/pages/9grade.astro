---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Grade 9 Exams" isUserLoggedIn={true}>
        
        <section class="relative overflow-hidden bg-secondary rounded-[48px] p-12 text-white shadow-2xl shadow-secondary/20 group mb-12 border-4 border-white/5">
            <div class="relative z-10 space-y-5">
                <span class="bg-white/20 backdrop-blur-md px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-white/10 inline-block italic">Current Focus</span>
                <h2 class="text-4xl md:text-5xl font-black italic tracking-tighter uppercase leading-tight">Grade 9 Exams</h2>
                <p class="opacity-80 max-w-md font-medium text-base leading-relaxed italic pr-4">
                    Master your curriculum with our curated mock exams and past papers. Aim for the stars!
                </p>
            </div>
            
            <div class="absolute -right-10 -top-10 w-64 h-64 bg-[#feb300]/20 rounded-full blur-3xl pointer-events-none group-hover:scale-125 transition-transform duration-1000"></div>
            <div class="absolute right-12 bottom-12 opacity-30 text-8xl material-symbols-outlined pointer-events-none filled-icon" style="font-variation-settings: 'FILL' 1;">auto_awesome</div>
        </section>

        <div class="flex items-center justify-between mb-8 px-6">
            <h3 class="text-xl font-black text-[#213041] tracking-[0.1em] uppercase italic">Mock Exams</h3>
            <button class="text-primary font-black text-[10px] uppercase tracking-[0.2em] hover:opacity-80 transition-all italic underline decoration-2 underline-offset-4">View Statistics</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            
            <a href="/finalexam" class="group relative rounded-[40px] bg-[#b5161e] p-8 text-white flex flex-col justify-between min-h-[300px] shadow-2xl shadow-[#b5161e]/20 active:scale-[0.97] transition-all cursor-pointer border-4 border-white/10 no-underline overflow-hidden">
                <div class="absolute -top-4 -right-4 opacity-20 group-hover:scale-125 group-hover:rotate-12 transition-transform duration-700">
                    <span class="material-symbols-outlined !text-[120px]" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-8">
                        <span class="bg-white/20 px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest border border-white/10 italic">In Progress</span>
                    </div>
                    <h4 class="text-2xl font-black italic tracking-tight uppercase leading-none mb-2">Mock Exam 1</h4>
                    <p class="text-xs opacity-70 font-medium italic">Full Curriculum Assessment</p>
                </div>
                <div class="space-y-4 relative z-10">
                    <div class="flex justify-between items-end text-[9px] font-black uppercase tracking-[0.2em] opacity-80 italic">
                        <span>Progress</span>
                        <span>65%</span>
                    </div>
                    <div class="h-3 w-full bg-white/20 rounded-full overflow-hidden shadow-inner p-0.5 border border-white/5">
                        <div class="h-full bg-[#feb300] rounded-full shadow-[0_0_15px_rgba(255,179,0,0.6)] animate-pulse" style="width: 65%"></div>
                    </div>
                </div>
            </a>

            <div class="group relative rounded-[40px] bg-white p-8 flex flex-col justify-between min-h-[300px] border-2 border-[#d1e4ff] shadow-xl shadow-[#155f98]/5 active:scale-[0.97] transition-all cursor-pointer">
                <div>
                    <div class="flex items-center gap-2 mb-8">
                        <span class="bg-[#f3f6ff] text-[#213041]/40 px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest border border-[#d1e4ff] italic">Not Started</span>
                    </div>
                    <h4 class="text-2xl font-black text-[#213041] italic tracking-tight uppercase leading-none mb-2">Mock Exam 2</h4>
                    <p class="text-xs text-[#213041]/50 font-medium leading-relaxed italic">Mid-Term Specialized Unit</p>
                </div>
                <button class="w-full bg-primary text-white font-black py-4 rounded-full flex items-center justify-center gap-3 shadow-lg shadow-primary/20 uppercase text-[10px] tracking-[0.2em] italic active:scale-90 transition-all">
                    Start Now
                    <span class="material-symbols-outlined !text-xl">play_arrow</span>
                </button>
            </div>

            <div class="group relative rounded-[40px] bg-white p-8 flex flex-col justify-between min-h-[300px] border-2 border-[#d1e4ff] shadow-xl shadow-[#155f98]/5 active:scale-[0.97] transition-all cursor-pointer">
                <div class="absolute top-8 right-8 text-[#feb300]">
                    <span class="material-symbols-outlined !text-4xl filled-icon" style="font-variation-settings: 'FILL' 1;">verified</span>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-8">
                        <span class="bg-[#feb300]/10 text-[#feb300] px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest italic border border-[#feb300]/10">Completed</span>
                    </div>
                    <h4 class="text-2xl font-black text-[#213041] italic tracking-tight uppercase leading-none mb-2">Mock Exam 3</h4>
                    <p class="text-xs text-[#213041]/50 font-medium italic pr-10">General Knowledge Assessment</p>
                </div>
                <div class="flex items-center justify-between p-5 bg-[#f3f6ff] rounded-[24px] border border-[#d1e4ff]">
                    <span class="text-[10px] font-black text-[#b5161e] uppercase tracking-[0.1em] italic">Score: 92%</span>
                    <span class="text-primary font-black text-[10px] uppercase tracking-[0.1em] cursor-pointer hover:underline italic">Review</span>
                </div>
            </div>
        </div>

        <h3 class="text-xl font-black text-[#213041] tracking-[0.1em] mb-8 px-6 uppercase italic">Past Papers</h3>
        
        <div class="space-y-5 px-4 pb-20">
            <div class="group flex items-center gap-6 bg-white p-6 rounded-[32px] border-2 border-[#d1e4ff] shadow-xl shadow-[#155f98]/5 active:scale-[0.98] transition-all cursor-pointer hover:border-[#155f98]/20">
                <div class="w-16 h-16 bg-[#f3f6ff] rounded-[24px] flex items-center justify-center text-[#b5161e] font-black text-2xl italic shadow-inner border border-[#d1e4ff]">
                    02
                </div>
                <div class="flex-1">
                    <h5 class="font-black text-[#213041] italic uppercase text-sm tracking-tight">Past Paper 2022 - Finals</h5>
                    <p class="text-[9px] font-black text-[#213041]/40 uppercase tracking-[0.2em] mt-1 italic">Full Set • 120 Minutes</p>
                </div>
                <div class="flex items-center gap-4">
                    <span class="bg-[#feb300] text-white px-5 py-2 rounded-full text-[9px] font-black uppercase tracking-[0.2em] shadow-lg shadow-[#feb300]/20 italic">Ready</span>
                    <span class="material-symbols-outlined text-primary !text-2xl group-hover:translate-x-2 transition-transform">chevron_right</span>
                </div>
            </div>
        </div>
</MainLayout>