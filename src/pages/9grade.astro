---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/9grade.css';
---

<MainLayout title="Grade 9 Exams">
    
    <section class="exam-banner group">
        <div class="relative z-10">
            <span class="exam-banner-badge">Current Focus</span>
            <h2 class="exam-banner-title">Grade 9 Exams</h2>
            <p class="exam-banner-text">
                Master your curriculum with our curated mock exams and past papers. Aim for the stars!
            </p>
        </div>
        
        <div class="absolute -right-10 -top-10 w-64 md:w-80 h-64 md:h-80 bg-[#feb300]/20 rounded-full blur-3xl pointer-events-none group-hover:scale-150 transition-transform duration-1000"></div>
        <div class="absolute right-6 bottom-6 md:right-12 md:bottom-12 opacity-20 text-[100px] md:text-[180px] material-symbols-outlined pointer-events-none group-hover:rotate-12 transition-transform duration-700">auto_awesome</div>
    </section>

    <div class="section-header">
        <h3 class="section-title">Mock Exams</h3>
        <button class="text-primary font-black text-[10px] md:text-xs uppercase tracking-widest hover:underline decoration-2 underline-offset-8 transition-all">View Statistics</button>
    </div>

    <div class="exams-grid">
        <a href="/finalexam" class="group relative rounded-[32px] md:rounded-[48px] bg-[#b5161e] p-8 md:p-10 text-white flex flex-col justify-between min-h-[300px] md:min-h-[350px] shadow-2xl shadow-red-900/20 active:scale-[0.97] transition-all cursor-pointer border-4 border-white/10 no-underline overflow-hidden">
            <div class="absolute -top-4 -right-4 opacity-20 group-hover:scale-125 group-hover:rotate-12 transition-transform duration-700">
                <span class="material-symbols-outlined !text-[100px] md:!text-[150px]">star</span>
            </div>
            <div>
                <span class="bg-white/20 px-4 py-1.5 rounded-full text-[9px] md:text-[10px] font-black uppercase tracking-widest border border-white/10 mb-6 md:mb-8 inline-block">In Progress</span>
                <h4 class="text-2xl md:text-3xl font-black tracking-tight uppercase leading-none mb-3">Mock Exam 1</h4>
                <p class="text-xs md:text-sm opacity-70 font-medium italic">Full Curriculum Assessment</p>
            </div>
            <div class="space-y-4 relative z-10">
                <div class="flex justify-between items-end text-[9px] md:text-[10px] font-black uppercase tracking-widest opacity-80">
                    <span>Progress</span>
                    <span>65%</span>
                </div>
                <div class="h-2.5 md:h-3 w-full bg-white/20 rounded-full overflow-hidden p-0.5 border border-white/5">
                    <div class="h-full bg-[#feb300] rounded-full shadow-[0_0_15px_rgba(255,179,0,0.6)]" style="width: 65%"></div>
                </div>
            </div>
        </a>

        <div class="group relative rounded-[32px] md:rounded-[48px] bg-white p-8 md:p-10 flex flex-col justify-between min-h-[300px] md:min-h-[350px] border-2 border-[#d1e4ff] shadow-xl shadow-blue-900/5 active:scale-[0.97] transition-all cursor-pointer">
            <div>
                <span class="bg-[#f3f6ff] text-[#213041]/40 px-4 py-1.5 rounded-full text-[9px] md:text-[10px] font-black uppercase tracking-widest border border-[#d1e4ff] mb-6 md:mb-8 inline-block">Not Started</span>
                <h4 class="text-2xl md:text-3xl font-black text-[#213041] tracking-tight uppercase leading-none mb-3">Mock Exam 2</h4>
                <p class="text-xs md:text-sm text-[#213041]/50 font-medium leading-relaxed">Mid-Term Specialized Unit</p>
            </div>
            <button class="w-full bg-primary text-white font-black py-4 md:py-5 rounded-full flex items-center justify-center gap-3 shadow-lg shadow-red-900/20 uppercase text-[10px] md:text-xs tracking-widest active:scale-95 transition-all">
                Start Now
                <span class="material-symbols-outlined !text-xl md:!text-2xl">play_arrow</span>
            </button>
        </div>

        <div class="group relative rounded-[32px] md:rounded-[48px] bg-white p-8 md:p-10 flex flex-col justify-between min-h-[300px] md:min-h-[350px] border-2 border-[#d1e4ff] shadow-xl shadow-blue-900/5 active:scale-[0.97] transition-all cursor-pointer">
            <div class="absolute top-8 right-8 md:top-10 md:right-10 text-[#feb300]">
                <span class="material-symbols-outlined !text-4xl md:!text-5xl">verified</span>
            </div>
            <div>
                <span class="bg-[#feb300]/10 text-[#feb300] px-4 py-1.5 rounded-full text-[9px] md:text-[10px] font-black uppercase tracking-widest border border-[#feb300]/10 mb-6 md:mb-8 inline-block">Completed</span>
                <h4 class="text-2xl md:text-3xl font-black text-[#213041] tracking-tight uppercase leading-none mb-3">Mock Exam 3</h4>
                <p class="text-xs md:text-sm text-[#213041]/50 font-medium pr-10">General Knowledge Assessment</p>
            </div>
            <div class="flex items-center justify-between p-5 md:p-6 bg-[#f3f6ff] rounded-[24px] md:rounded-[32px] border border-[#d1e4ff]">
                <span class="text-[10px] md:text-xs font-black text-[#b5161e] uppercase tracking-widest">Score: 92%</span>
                <span class="text-primary font-black text-[10px] md:text-xs uppercase tracking-widest hover:underline cursor-pointer">Review</span>
            </div>
        </div>
    </div>

    <h3 class="section-title mb-8 md:mb-10 px-4 md:px-6">Past Papers</h3>
    
    <div class="past-papers-list">
        <div class="past-paper-item group">
            <div class="past-paper-number">22</div>
            <div class="flex-1">
                <h5 class="font-black text-[#213041] uppercase text-sm md:text-lg tracking-tight">Past Paper 2022 - Finals</h5>
                <p class="text-[9px] md:text-xs font-black text-[#213041]/40 uppercase tracking-widest mt-1">Full Set • 120 Minutes</p>
            </div>
            <div class="flex items-center gap-4 md:gap-6">
                <span class="hidden sm:block bg-[#feb300] text-white px-4 py-2 md:px-6 md:py-2.5 rounded-full text-[9px] md:text-xs font-black uppercase tracking-widest shadow-lg shadow-yellow-600/20">Ready</span>
                <span class="material-symbols-outlined text-primary !text-2xl md:!text-3xl group-hover:translate-x-3 transition-transform">chevron_right</span>
            </div>
        </div>
    </div>

</MainLayout>