---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/9grade.css';
---

<MainLayout title="Grade 9 Exams">
    <!-- Standart Göy üçün 'theme-pink' class-ını silmək kifayətdir -->
    <div class="theme-pink min-h-screen pb-20">
        
        <!-- Ana Banner -->
        <section class="theme-banner group relative overflow-hidden rounded-[24px] md:rounded-[40px] p-8 md:p-14 text-white shadow-2xl mb-8 md:mb-12 border-2 md:border-4 border-white/10 transition-all duration-500">
            <div class="relative z-10">
                <span class="bg-white/20 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-white/10 inline-block mb-5">
                    Current Focus
                </span>
                <h2 class="text-3xl md:text-5xl lg:text-6xl font-black tracking-tighter uppercase leading-none mb-4 italic">Grade 9 Exams</h2>
                <p class="opacity-80 max-w-lg font-medium text-sm md:text-base leading-relaxed italic">
                    Master your curriculum with our curated mock exams and past papers. Aim for the stars!
                </p>
            </div>
            
            <div class="absolute -right-10 -top-10 w-64 md:w-80 h-64 md:h-80 bg-white/10 rounded-full blur-3xl pointer-events-none group-hover:scale-150 transition-transform duration-1000"></div>
            <div class="absolute right-6 bottom-6 md:right-12 md:bottom-12 opacity-20 text-[120px] md:text-[200px] material-symbols-outlined pointer-events-none group-hover:rotate-12 transition-transform duration-700">auto_awesome</div>
        </section>

        <!-- Mock Exams Header -->
        <div class="flex items-center justify-between mb-8 px-4 md:px-6">
            <h3 class="text-xl md:text-2xl font-black text-slate-800 uppercase tracking-tight italic">Mock Exams</h3>
            <button class="theme-text-link font-black text-xs uppercase tracking-widest hover:underline decoration-2 underline-offset-8 transition-all">View Statistics</button>
        </div>

        <!-- Exams Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16 px-4 md:px-6">
            
            <!-- In Progress Card (Dinamik Rəngli) -->
            <a href="/finalexam" class="theme-card-main group relative rounded-[40px] p-8 md:p-10 text-white flex flex-col justify-between min-h-[320px] shadow-2xl transition-all cursor-pointer border-4 border-white/10 no-underline overflow-hidden active:scale-95">
                <div class="absolute -top-4 -right-4 opacity-20 group-hover:scale-125 group-hover:rotate-12 transition-transform duration-700">
                    <span class="material-symbols-outlined !text-[120px] md:!text-[160px]">star</span>
                </div>
                <div>
                    <span class="bg-white/20 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-white/10 mb-8 inline-block">In Progress</span>
                    <h4 class="text-2xl md:text-3xl font-black tracking-tight uppercase leading-none mb-3 italic text-balance">Mock Exam 1</h4>
                    <p class="text-sm opacity-70 font-medium italic italic">Full Curriculum Assessment</p>
                </div>
                <div class="space-y-4 relative z-10">
                    <div class="flex justify-between items-end text-[10px] font-black uppercase tracking-widest opacity-80">
                        <span>Progress</span>
                        <span>65%</span>
                    </div>
                    <div class="h-3 w-full bg-white/20 rounded-full overflow-hidden p-0.5 border border-white/5">
                        <div class="h-full theme-progress-bar rounded-full" style="width: 65%"></div>
                    </div>
                </div>
            </a>

            <!-- Not Started (Standart Ağ) -->
            <div class="group relative rounded-[40px] bg-white p-8 md:p-10 flex flex-col justify-between min-h-[320px] border-2 border-slate-100 shadow-xl shadow-slate-200/50 active:scale-[0.97] transition-all cursor-pointer">
                <div>
                    <span class="bg-slate-50 text-slate-400 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-slate-100 mb-8 inline-block">Not Started</span>
                    <h4 class="text-2xl md:text-3xl font-black text-slate-800 tracking-tight uppercase leading-none mb-3 italic">Mock Exam 2</h4>
                    <p class="text-sm text-slate-400 font-medium italic italic">Mid-Term Specialized Unit</p>
                </div>
                <button class="theme-button-solid w-full text-white font-black py-5 rounded-full flex items-center justify-center gap-3 shadow-lg transition-all uppercase text-xs tracking-widest italic">
                    Start Now
                    <span class="material-symbols-outlined !text-xl md:!text-2xl">play_arrow</span>
                </button>
            </div>
        </div>

        <!-- Past Papers -->
        <h3 class="text-xl md:text-2xl font-black text-slate-800 uppercase tracking-tight italic mb-8 px-4 md:px-6">Past Papers</h3>
        
        <div class="space-y-4 px-4 md:px-6 max-w-4xl">
            <div class="theme-past-paper group flex items-center gap-4 p-4 md:p-6 bg-white border-2 border-slate-100 rounded-[28px] shadow-sm hover:shadow-md transition-all cursor-pointer">
                <div class="theme-paper-number w-12 h-12 md:w-16 md:h-16 shrink-0 rounded-[20px] flex items-center justify-center font-black text-xl md:text-2xl shadow-inner italic italic">
                    22
                </div>
                <div class="flex-1">
                    <h5 class="font-black text-slate-800 uppercase text-sm md:text-lg tracking-tight italic">Past Paper 2022 - Finals</h5>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">Full Set • 120 Minutes</p>
                </div>
                <div class="flex items-center gap-4">
                    <span class="hidden sm:block bg-yellow-400 text-white px-6 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg shadow-yellow-600/20 italic">Ready</span>
                    <span class="material-symbols-outlined theme-text-link !text-3xl group-hover:translate-x-2 transition-transform">chevron_right</span>
                </div>
            </div>
        </div>
    </div>
</MainLayout>