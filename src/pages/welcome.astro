---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Welcome Star Student" hideHeader={false} hideNavbar={false}>
    
    <section class="flex flex-col items-center justify-center py-12 text-center space-y-10 relative overflow-hidden">
        
        <div class="relative group">
            <div class="absolute inset-0 bg-[#feb300] blur-3xl opacity-20 animate-pulse group-hover:opacity-40 transition-opacity"></div>
            <span class="material-symbols-outlined !text-[120px] text-[#feb300] relative z-10 drop-shadow-lg filled-icon" style="font-variation-settings: 'FILL' 1;">
                stars
            </span>
        </div>

        <div class="space-y-4 px-4">
            <h1 class="text-4xl font-black text-[#213041] italic uppercase tracking-tighter leading-tight">
                You're a <span class="text-[#b5161e]">Star</span> Now!
            </h1>
            <p class="text-[#213041]/60 font-medium max-w-md mx-auto italic leading-relaxed text-sm">
                Your registration is successfully completed. Start your first lesson now by choosing an option below!
            </p>
        </div>

        <div class="grid grid-cols-1 gap-5 w-full max-w-md px-6">
            
            <a href="/topics" class="p-8 bg-white rounded-[40px] border-2 border-[#d1e4ff] hover:border-[#b5161e] transition-all no-underline text-left flex items-center gap-6 group active:scale-95 shadow-lg shadow-[#155f98]/5">
                <div class="bg-[#b5161e] text-white p-5 rounded-[24px] shadow-xl shadow-[#b5161e]/20 group-hover:scale-110 transition-transform flex-shrink-0">
                    <span class="material-symbols-outlined filled-icon" style="font-variation-settings: 'FILL' 1;">auto_stories</span>
                </div>
                <div class="flex-grow">
                    <h4 class="font-black text-[#213041] text-base uppercase italic tracking-tight">Start Learning</h4>
                    <p class="text-[10px] text-[#213041]/40 font-black uppercase tracking-widest mt-1">First Topic: Nouns</p>
                </div>
                <span class="material-symbols-outlined ml-auto text-[#213041]/20 group-hover:text-[#b5161e] group-hover:translate-x-1.5 transition-all !text-xl">arrow_forward</span>
            </a>

            <a href="/profile" class="p-8 bg-white rounded-[40px] border-2 border-[#d1e4ff] hover:border-[#155f98] transition-all no-underline text-left flex items-center gap-6 group active:scale-95 shadow-lg shadow-[#155f98]/5">
                <div class="bg-[#155f98] text-white p-5 rounded-[24px] shadow-xl shadow-[#155f98]/20 group-hover:scale-110 transition-transform flex-shrink-0">
                    <span class="material-symbols-outlined filled-icon" style="font-variation-settings: 'FILL' 1;">person_pin</span>
                </div>
                <div class="flex-grow">
                    <h4 class="font-black text-[#213041] text-base uppercase italic tracking-tight">Setup Profile</h4>
                    <p class="text-[10px] text-[#213041]/40 font-black uppercase tracking-widest mt-1">Set your avatar</p>
                </div>
                <span class="material-symbols-outlined ml-auto text-[#213041]/20 group-hover:text-[#155f98] group-hover:translate-x-1.5 transition-all !text-xl">arrow_forward</span>
            </a>
        </div>

        <p class="text-[10px] font-black text-[#213041]/30 uppercase tracking-[0.2em] pt-8 italic px-6">
            Navigate through the grammar galaxies using the navigation bar below
        </p>
        
        <div class="absolute -top-10 -left-10 w-40 h-40 bg-white/50 blur-3xl rounded-full -z-10"></div>
        <div class="absolute bottom-20 -right-10 w-64 h-64 bg-[#83bdfd]/10 blur-3xl rounded-full -z-10"></div>

    </section>
</MainLayout>

<style>
    /* Ensure icon fill settings */
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .filled-icon {
        font-variation-settings: 'FILL' 1;
    }
</style>