---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/login.css';
---

<MainLayout title="Login" isIndex={true} hideHeader={true} hideNavbar={true}>
    
    <div class="login-bg-decor">
        <div class="absolute top-[15%] left-[10%] text-[#155f98]/10">
            <span class="material-symbols-outlined !text-9xl rotate-12">star</span>
        </div>
        <div class="absolute bottom-[10%] right-[5%] text-[#feb300]/10">
            <span class="material-symbols-outlined !text-[160px] -rotate-12">auto_awesome</span>
        </div>
    </div>

    <section class="login-section">
        
        <div class="mb-10 text-center">
            <div class="flex items-center justify-center mb-6">
                <div class="p-4 bg-[#155f98] rounded-[28px] shadow-2xl shadow-blue-900/20">
                    <span class="material-symbols-outlined text-white text-4xl">auto_awesome</span>
                </div>
            </div>
            <h1 class="text-3xl font-black text-[#213041] tracking-tighter uppercase">
                Teacher <span class="text-[#af101a]">Roya’s</span> Stars
            </h1>
            <p class="text-slate-400 font-medium mt-2 text-sm">Your journey to the stars starts here.</p>
        </div>

        <div class="login-card">
            <div class="mb-8">
                <h2 class="text-2xl font-black text-[#213041] uppercase tracking-tight">Welcome Back</h2>
                <p class="text-slate-400 text-sm mt-1 font-medium">Please enter your credentials</p>
            </div>

            <form id="login-form" class="space-y-5">
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-[#155f98] ml-2">Email Address</label>
                    <input required class="login-input" placeholder="example@roya.edu" type="email" />
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center px-2">
                        <label class="text-[10px] font-black uppercase tracking-widest text-[#155f98]">Password</label>
                        <a href="#" class="text-[10px] font-black text-[#af101a] uppercase hover:underline">Forgot?</a>
                    </div>
                    <div class="relative flex items-center">
                        <input required class="login-input pr-12" placeholder="••••••••" type="password" />
                        <button class="absolute right-4 text-slate-400 hover:text-primary" type="button">
                            <span class="material-symbols-outlined text-lg">visibility</span>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    Login Now <span class="material-symbols-outlined !text-xl">rocket_launch</span>
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-slate-50 text-center">
                <p class="text-sm text-slate-400 font-medium">Don't have an account?</p>
                <a class="inline-block mt-2 text-[#155f98] font-black uppercase text-xs tracking-widest hover:underline" href="/signup">Sign up for Teacher Roya’s Stars</a>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-8 w-full max-w-md px-2">
            <div class="stat-card bg-blue-50 border-blue-100">
                <span class="material-symbols-outlined text-blue-600 mb-1">school</span>
                <span class="text-[9px] font-black text-blue-600 uppercase tracking-widest">Student Hub</span>
            </div>
            <div class="stat-card bg-yellow-50 border-yellow-100">
                <span class="material-symbols-outlined text-yellow-600 mb-1">star_rate</span>
                <span class="text-[9px] font-black text-yellow-700 uppercase tracking-widest">Star Rewards</span>
            </div>
        </div>
    </section>

</MainLayout>

<script>
    const loginForm = document.getElementById('login-form');
    if (loginForm) {
        loginForm.addEventListener('submit', (e) => {
            e.preventDefault();
            window.location.href = '/welcome';
        });
    }
</script>