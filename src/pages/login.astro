---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Login" isIndex={true} hideHeader={true} hideNavbar={true}>
    
    <div class="fixed top-0 left-0 w-full h-full pointer-events-none overflow-hidden -z-20">
        <div class="absolute top-[15%] left-[10%] text-[#155f98]/10">
            <span class="material-symbols-outlined !text-9xl rotate-12">star</span>
        </div>
        <div class="absolute bottom-[10%] right-[5%] text-[#feb300]/10">
            <span class="material-symbols-outlined !text-[10rem] -rotate-12">auto_awesome</span>
        </div>
    </div>

    <section class="flex flex-col items-center justify-center min-h-[85vh] relative py-12">
        
        <div class="mb-10 text-center">
            <div class="flex items-center justify-center mb-6">
                <div class="p-4 bg-[#155f98] rounded-[28px] shadow-2xl shadow-[#155f98]/20 group hover:rotate-6 transition-transform">
                    <span class="material-symbols-outlined text-white text-4xl filled-icon" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                </div>
            </div>
            <h1 class="text-3xl font-black text-[#213041] tracking-tighter uppercase italic">
                Teacher <span class="text-[#b5161e]">Roya’s</span> Stars
            </h1>
            <p class="text-[#213041]/50 font-medium mt-2 italic">Your journey to the stars starts here.</p>
        </div>

        <div class="w-full max-w-md bg-white rounded-[48px] p-10 shadow-2xl shadow-[#155f98]/5 border border-white/40 relative">
            
            <div class="absolute -top-4 -right-4 w-16 h-16 text-[#feb300] rotate-12 opacity-80">
                <span class="material-symbols-outlined text-5xl filled-icon" style="font-variation-settings: 'FILL' 1;">stars</span>
            </div>

            <div class="mb-10">
                <h2 class="text-2xl font-black text-[#213041] uppercase italic tracking-tight">Welcome Back</h2>
                <p class="text-[#213041]/50 text-sm mt-1 italic font-medium">Please enter your credentials to continue</p>
            </div>

            <form id="login-form" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-[0.2em] text-[#155f98] ml-2 italic">Email Address</label>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#69788c] text-lg">mail</span>
                        <input required class="w-full pl-12 pr-4 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-4 focus:ring-[#83bdfd]/30 text-[#213041] font-bold outline-none transition-all placeholder:text-[#69788c]/40 text-sm italic" placeholder="example@roya.edu" type="email" />
                    </div>
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center px-2">
                        <label class="text-[10px] font-black uppercase tracking-[0.2em] text-[#155f98] italic">Password</label>
                        <a href="#" class="text-[10px] font-black text-[#b5161e] uppercase tracking-widest hover:underline italic">Forgot?</a>
                    </div>
                    <div class="relative flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-[#69788c] text-lg">lock</span>
                        <input required class="w-full pl-12 pr-12 py-4 bg-[#f3f6ff] border-none rounded-2xl focus:ring-4 focus:ring-[#83bdfd]/30 text-[#213041] font-bold outline-none transition-all text-sm italic" placeholder="••••••••" type="password" />
                        <button class="absolute right-4 text-[#69788c] hover:text-[#155f98]" type="button">
                            <span class="material-symbols-outlined text-lg">visibility</span>
                        </button>
                    </div>
                </div>

                <button type="submit" class="w-full bg-[#b5161e] text-white py-5 mt-4 rounded-full font-black text-sm uppercase tracking-[0.2em] shadow-xl shadow-[#b5161e]/20 active:scale-95 transition-all flex items-center justify-center gap-2 italic">
                    Login Now
                    <span class="material-symbols-outlined !text-xl">rocket_launch</span>
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-[#f3f6ff] text-center">
                <p class="text-sm text-[#213041]/50 font-medium italic">Don't have an account?</p>
                <a class="inline-block mt-2 text-[#155f98] font-black uppercase text-xs tracking-widest hover:underline" href="/signup">Sign up for Teacher Roya’s Stars</a>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-8 w-full max-w-md px-4">
            <div class="bg-[#155f98]/5 p-4 rounded-3xl flex flex-col items-center text-center border border-[#155f98]/10">
                <span class="material-symbols-outlined text-[#155f98] mb-1">school</span>
                <span class="text-[9px] font-black text-[#155f98] uppercase tracking-widest italic">Student Hub</span>
            </div>
            <div class="bg-[#feb300]/10 p-4 rounded-3xl flex flex-col items-center text-center border border-[#feb300]/10">
                <span class="material-symbols-outlined text-[#feb300] mb-1">star_rate</span>
                <span class="text-[9px] font-black text-[#7b5400] uppercase tracking-widest italic">Star Rewards</span>
            </div>
        </div>
    </section>

</MainLayout>

<script>
    const loginForm = document.getElementById('login-form');
    
    if (loginForm) {
        loginForm.addEventListener('submit', (e) => {
            e.preventDefault(); // Səhifənin yenilənməsini dayandırır
            
            // Welcome səhifəsinə yönləndirir
            window.location.href = '/welcome';
        });
    }
</script>