---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/login.css';
---

<MainLayout title="Login" isIndex={true} hideHeader={true} hideNavbar={true}>
    
    <!-- Background Decor -->
    <div class="login-bg-decor fixed inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-[10%] left-[5%] text-primary/10">
            <span class="material-symbols-outlined !text-[10rem] md:!text-[15rem] rotate-12">star</span>
        </div>
        <div class="absolute bottom-[10%] right-[2%] text-primary/10">
            <span class="material-symbols-outlined !text-[12rem] md:!text-[18rem] -rotate-12">auto_awesome</span>
        </div>
    </div>

    <section class="min-h-screen flex flex-col items-center justify-center p-6 relative z-10">
        
        <!-- Logo & Header -->
        <div class="mb-8 text-center">
            <div class="flex items-center justify-center mb-5">
                <div class="bg-primary p-4 rounded-lg shadow-xl shadow-primary/20">
                    <span class="material-symbols-outlined text-white !text-3xl">auto_awesome</span>
                </div>
            </div>
            <h1 class="text-2xl md:text-4xl font-black text-on-surface tracking-tighter uppercase italic leading-none">
                Teacher <span class="text-secondary">Roya’s</span> Stars
            </h1>
            <p class="text-on-surface-variant font-bold mt-2 text-xs uppercase tracking-widest italic opacity-70">
                Your journey to the stars starts here.
            </p>
        </div>

        <!-- Login Card -->
        <div class="w-full max-w-md bg-surface-container-lowest border-2 border-surface-container-high p-8 md:p-12 rounded-xl shadow-2xl shadow-on-surface/5">
            <div class="mb-10">
                <h2 class="text-xl md:text-3xl font-black text-on-surface uppercase tracking-tight italic">Welcome Back</h2>
                <p class="text-on-surface-variant text-xs mt-1 font-bold uppercase tracking-widest italic opacity-50">Please enter your credentials</p>
            </div>

            <form id="login-form" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-primary ml-2">Email Address</label>
                    <input required class="login-input" placeholder="example@roya.edu" type="email" />
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center px-2">
                        <label class="text-[10px] font-black uppercase tracking-widest text-primary">Password</label>
                        <a href="#" class="text-[10px] font-black text-secondary uppercase hover:underline tracking-widest transition-colors">Forgot?</a>
                    </div>
                    <div class="relative flex items-center">
                        <input required class="login-input pr-12" placeholder="••••••••" type="password" />
                        <button class="absolute right-5 text-on-surface-variant/30 hover:text-primary transition-colors" type="button">
                            <span class="material-symbols-outlined !text-xl">visibility</span>
                        </button>
                    </div>
                </div>

                <button type="submit" class="bg-secondary w-full text-white py-5 rounded-full font-black flex items-center justify-center gap-3 shadow-lg shadow-secondary/20 active:scale-95 transition-all uppercase text-xs tracking-widest italic">
                    Login Now <span class="material-symbols-outlined !text-xl">rocket_launch</span>
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-surface-container-high text-center">
                <p class="text-[10px] text-on-surface-variant font-black uppercase tracking-widest">Don't have an account?</p>
                <a class="inline-block mt-3 text-secondary font-black uppercase text-xs tracking-widest hover:underline italic" href="/signup">Sign up for Teacher Roya’s Stars</a>
            </div>
        </div>

        <!-- Bottom Hub Cards -->
        <div class="grid grid-cols-2 gap-4 mt-10 w-full max-w-md">
            <div class="group bg-surface-container-lowest/60 backdrop-blur-md border border-surface-container-high p-5 rounded-lg flex flex-col items-center gap-3 transition-all cursor-pointer hover:bg-white hover:shadow-xl active:scale-95">
                <div class="w-12 h-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center group-hover:scale-110 transition-transform shadow-inner">
                    <span class="material-symbols-outlined !text-2xl">school</span>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant group-hover:text-primary transition-colors">Student Hub</span>
            </div>
            <div class="group bg-surface-container-lowest/60 backdrop-blur-md border border-surface-container-high p-5 rounded-lg flex flex-col items-center gap-3 transition-all cursor-pointer hover:bg-white hover:shadow-xl active:scale-95">
                <div class="w-12 h-12 rounded-lg bg-tertiary/10 text-tertiary flex items-center justify-center group-hover:scale-110 transition-transform shadow-inner">
                    <span class="material-symbols-outlined !text-2xl">workspace_premium</span>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant group-hover:text-tertiary transition-colors">Star Rewards</span>
            </div>
        </div>
    </section>

</MainLayout>

<script>
    const loginForm = document.getElementById('login-form');
    if (loginForm) {
        loginForm.addEventListener('submit', (e) => {
            e.preventDefault();
            window.location.href = '/welcome';
        });
    }
</script>