---
interface Props {
  variant?: 'red' | 'white' | 'gray';
  href?: string;
  badgeText?: string;
  title: string;
  description: string;
  progress?: string;
  iconName?: string;
}

const { 
  variant = 'white', 
  href, 
  badgeText, 
  title, 
  description, 
  progress, 
  iconName = "star" 
} = Astro.props;

// Dizayn Variantları - Künclər rounded-[48px] (Çox yumşaq)
const variants = {
  red: "bg-secondary text-white shadow-2xl shadow-secondary/20 border-white/5 hover:brightness-110",
  white: "bg-white text-on-surface border-primary/5 shadow-md hover:shadow-xl hover:border-primary/10",
  gray: "bg-surface-variant/30 border-primary/5 grayscale opacity-60 pointer-events-none"
};

const Element = href ? 'a' : 'div';
---

<Element 
  href={href} 
  class:list={[
    "relative group p-10 rounded-[48px] flex flex-col justify-between min-h-[300px] transition-all duration-300 active:scale-[0.97] border-4 block overflow-hidden",
    variants[variant]
  ]}
>
  <div class="absolute -top-4 -right-4 opacity-20 group-hover:scale-110 group-hover:rotate-12 transition-transform duration-500 pointer-events-none select-none">
    <span class="material-symbols-outlined !text-9xl" style="font-variation-settings: 'FILL' 1;">
      {iconName}
    </span>
  </div>

  <div class="relative z-10 space-y-6">
    {badgeText && (
      <span class:list={[
        "inline-block px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-widest border self-start shadow-sm",
        variant === 'red' ? 'bg-white/20 border-white/10' : 'bg-surface border-primary/5'
      ]}>
        {badgeText}
      </span>
    )}

    <div>
        <h3 class="text-3xl font-black italic tracking-tight leading-tight uppercase mb-2">{title}</h3>
        <p class:list={[
            "text-sm font-medium leading-relaxed italic pr-10",
            variant === 'red' ? 'text-white/80' : 'text-on-surface/50'
        ]}>
            {description}
        </p>
    </div>
  </div>

  <div class="mt-auto pt-8 space-y-4 relative z-10">
    {progress && (
      <>
        <div class="flex justify-between items-end text-[11px] font-black uppercase tracking-widest opacity-80 italic">
          <span>{variant === 'red' ? 'Progress' : 'Ready Status'}</span>
          <span>{progress}%</span>
        </div>
        <div class:list={[
          "h-3 w-full rounded-full overflow-hidden shadow-inner p-0.5 border",
          variant === 'red' ? 'bg-white/20 border-white/5' : 'bg-surface border-primary/5'
        ]}>
          <div 
              class="h-full bg-tertiary rounded-full shadow-[0_0_15px_rgba(255,179,0,0.7)] transition-all duration-1000 ease-out" 
              style={`width: ${progress}%`}
          ></div>
        </div>
      </>
    )}
    
    <div class:list={[
        "w-full py-4 rounded-full font-black text-center text-xs uppercase tracking-widest shadow-lg transition-all active:scale-95",
        variant === 'red' ? 'bg-white text-secondary' : 'bg-secondary text-white'
    ]}>
        {variant === 'red' ? 'Review Mission' : variant === 'gray' ? 'Locked' : 'Continue Learning'}
    </div>
  </div>
</Element>