---
interface Props {
  variant?: 'red' | 'white' | 'gray';
  href?: string;
  badgeText?: string;
  title: string;
  description: string;
  progress?: string;
  iconName?: string;
  class?: string; 
}

const { 
  variant = 'white', 
  href, 
  badgeText, 
  title, 
  description, 
  progress, 
  iconName = "star",
  class: className 
} = Astro.props;

const variants = {
  red: "bg-[#b5161e] text-white shadow-xl shadow-[#b5161e]/15 border-white/10 hover:brightness-105",
  white: "bg-white text-[#213041] border-[#d1e4ff] shadow-sm hover:shadow-lg hover:border-[#155f98]/20",
  gray: "bg-[#f3f6ff] border-[#d1e4ff] grayscale opacity-60 pointer-events-none"
};

const Element = href ? 'a' : 'div';
---

<Element 
  href={href} 
  class:list={[
    "relative group p-5 md:p-7 rounded-[28px] md:rounded-[32px] flex flex-col justify-between min-h-[200px] md:min-h-[240px] transition-all duration-300 active:scale-[0.98] border-2 block overflow-hidden no-underline",
    variants[variant],
    className
  ]}
>
  <div class="absolute -top-3 -right-3 opacity-10 group-hover:scale-110 group-hover:rotate-12 transition-transform duration-700 pointer-events-none select-none">
    <span class="material-symbols-outlined !text-[70px] md:!text-[100px]" style="font-variation-settings: 'FILL' 1;">
      {iconName}
    </span>
  </div>

  <div class="relative z-10 space-y-3 md:space-y-4">
    {badgeText && (
      <span class:list={[
        "inline-block px-3 py-1 rounded-full text-[8px] md:text-[9px] font-black uppercase tracking-[0.15em] border self-start shadow-sm italic",
        variant === 'red' ? 'bg-white/20 border-white/10' : 'bg-[#f3f6ff] border-[#d1e4ff]'
      ]}>
        {badgeText}
      </span>
    )}

    <div>
        <h3 class="text-lg md:text-2xl font-black italic tracking-tight leading-tight uppercase mb-1">{title}</h3>
        <p class:list={[
            "text-[10px] md:text-xs font-medium leading-relaxed italic pr-8",
            variant === 'red' ? 'text-white/80' : 'text-[#213041]/50'
        ]}>
            {description}
        </p>
    </div>
  </div>

  <div class="mt-auto pt-4 md:pt-6 space-y-3 md:space-y-4 relative z-10">
    {progress && (
      <div class="space-y-1.5 md:space-y-2">
        <div class="flex justify-between items-end text-[8px] md:text-[9px] font-black uppercase tracking-[0.2em] opacity-80 italic">
          <span>{variant === 'red' ? 'Mission Progress' : 'Ready Status'}</span>
          <span>{progress}%</span>
        </div>
        <div class:list={[
          "h-2 w-full rounded-full overflow-hidden shadow-inner p-0.5 border",
          variant === 'red' ? 'bg-white/20 border-white/5' : 'bg-[#f3f6ff] border-[#d1e4ff]'
        ]}>
          <div class="h-full bg-[#feb300] rounded-full shadow-[0_0_12px_rgba(255,179,0,0.6)]" style={`width: ${progress}%`}></div>
        </div>
      </div>
    )}
    
    <div class:list={[
        "w-full py-2.5 md:py-3.5 rounded-full font-black text-center text-[9px] md:text-[10px] uppercase tracking-[0.2em] shadow-lg italic",
        variant === 'red' ? 'bg-white text-[#b5161e]' : 'bg-[#b5161e] text-white'
    ]}>
        {variant === 'red' ? 'Review Mission' : variant === 'gray' ? 'Locked' : 'Continue Learning'}
    </div>
  </div>
</Element>